<script>
(function(){
const API=(document.getElementById('nuvio-qp-cfg')||{}).dataset?.apiBase||'https://nuvio-quoting-portal-production.up.railway.app';
const ADMIN_EMAIL='tom@nuvio.com.au';
const MONTHS=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
let sessionToken=localStorage.getItem('zq_token')||localStorage.getItem('nuvio_portal_token')||localStorage.getItem('za_token')||localStorage.getItem('bm_token')||null;
// Authenticated fetch — attaches token and handles 401 by forcing re-login
async function authFetch(url,opts={}){
  const headers={'Content-Type':'application/json',...(opts.headers||{})};
  if(sessionToken)headers['Authorization']='Bearer '+sessionToken;
  const r=await fetch(url,{...opts,headers});
  if(r.status===401){
    sessionToken=null;localStorage.removeItem('zq_token');localStorage.removeItem('nuvio_portal_token');
    alert('Your session has expired. Please log in again.');
    currentUser=null;zqShow('zq-login-screen');
    throw new Error('Session expired');
  }
  return r;
}
const DEFAULT_USERS=[
  {email:'tom@nuvio.com.au',pass:'Nuvio2026!',name:'Tom',role:'admin',commission:0},
  {email:'info@nuvio.com.au',pass:'Nuvio2026!',name:'Tom',role:'admin',commission:0},
  {email:'sales@nuvio.com.au',pass:'Sales2026!',name:'Sales',role:'staff',commission:10},
];
// Virtual salespeople that appear in filters/assignment but have no login
const VIRTUAL_SALESPEOPLE=['Website'];
let USERS=JSON.parse(localStorage.getItem('zq_users')||'null')||DEFAULT_USERS;
let currentUser=null,currentFilter='all',currentPage=1;
const QUOTES_PER_PAGE=15;
let activeQuoteId=null,editingQuoteId=null,newQuoteItems=[],searchTimer=null,poSearchTimer=null,custTimer=null,ncCustTimer=null,saveTimer=null,autocomplete=null;
let costsLoaded=false,productsLoaded=false,inventoryLoaded=false,posLoaded=false;
let allProducts=[],inventory={},variantToInvItem={},purchaseOrders=[],newPOItems=[],quotes=[];
let costs=JSON.parse(localStorage.getItem('zq_costs')||'{}');
// costs[variantId] can be a number (legacy) or {price, supplierCode, landedUSD}
function getCostData(vid){
  const raw=costs[String(vid)];
  if(!raw||typeof raw==='number')return{price:parseFloat(raw)||0,supplierCode:'',landedUSD:'',supplierName:''};
  return{price:parseFloat(raw.price)||0,supplierCode:raw.supplierCode||'',landedUSD:raw.landedUSD||'',supplierName:raw.supplierName||''};
}
let quoteCounter=100,activeFcTab='stock';
let newOrderQtys={};
let editingPOId=null;
let leadTimes={};
let salesCache={};
let salesLoaded=false;
let fcNeedsOrderOnly=false;
let stockSettings={};
let CLIENTS=[];
// calcData: { audUsd: 0.63, [variantId]: { packaging: 0, freight: 0 } }
let calcData=JSON.parse(localStorage.getItem('zq_calc')||'{}');
let costsTimer=null;
function debounceSaveCosts(){clearTimeout(costsTimer);costsTimer=setTimeout(saveCosts,800);}
async function saveSupplierCodeToShopify(vid,code){
  try{
    const r=await authFetch(API+'/variant-supplier-codes',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({variantId:vid,supplierCode:code})
    });
    const d=await r.json();
    if(d.ok){console.log('Supplier code saved to Shopify for variant '+vid);}
    else{console.warn('Shopify metafield save failed:',d.error);}
  }catch(e){console.warn('Supplier code Shopify sync failed:',e.message);}
}
async function saveCostAUDToShopify(vid,cost){
  const r=await authFetch(API+'/variant-costs',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({variantId:vid,cost})
  });
  const d=await r.json();
  if(!d.ok)throw new Error(d.error||'Unknown error');
  return d;
}
function fmt(n){return '$'+parseFloat(n||0).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g,',');}
function escHtml(s){return String(s||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function escHtml(s){return String(s||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function isAdmin(){return currentUser&&currentUser.role==='admin';}
function saveCosts(){
  localStorage.setItem('zq_costs',JSON.stringify(costs));
  // Always include __calc so a single endpoint call persists everything together
  const payload={...costs,__calc:calcData};
  authFetch(API+'/costs',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}).catch(()=>{});
}
async function loadCostsFromRailway(){
  try{
    const r=await authFetch(API+'/costs');const d=await r.json();
    if(d&&Object.keys(d).length){
      // Extract calc data — Railway is source of truth
      if(d.__calc){
        Object.assign(calcData,d.__calc);
        localStorage.setItem('zq_calc',JSON.stringify(calcData));
      }
      Object.keys(d).forEach(vid=>{
        if(vid==='__calc')return;
        const remote=d[vid];
        const remoteObj=typeof remote==='number'?{price:remote,supplierCode:'',landedUSD:'',supplierName:''}:remote;
        // Railway always wins over localStorage
        costs[String(vid)]={
          price:parseFloat(remoteObj.price)||0,
          supplierCode:remoteObj.supplierCode||'',
          landedUSD:remoteObj.landedUSD||'',
          supplierName:remoteObj.supplierName||''
        };
      });
      localStorage.setItem('zq_costs',JSON.stringify(costs));
    }
  }catch(e){
    // Offline fallback — use localStorage cache
    const local=JSON.parse(localStorage.getItem('zq_costs')||'{}');
    Object.assign(costs,local);
    const localCalc=JSON.parse(localStorage.getItem('zq_calc')||'{}');
    Object.assign(calcData,localCalc);
  }
}
function nextId(){quoteCounter++;return 'ZQ-'+String(quoteCounter).padStart(4,'0');}
function formatDate(d){return d.getDate()+' '+MONTHS[d.getMonth()]+' '+d.getFullYear();}
function today(){return formatDate(new Date());}
function expiryDate(){const d=new Date();d.setDate(d.getDate()+30);return formatDate(d);}
function setSyncStatus(msg){const el=document.getElementById('zq-sync-status');if(el)el.textContent=msg;}
function poNextId(){return 'PO-'+Date.now();}
function stockBadge(vid){
  if(!inventoryLoaded)return '';
  const qty=inventory[String(vid)]||0;
  if(qty<=0)return '<span class="zq-stock-badge zq-stock-out">Out</span>';
  if(qty<=5)return '<span class="zq-stock-badge zq-stock-low">'+qty+' left</span>';
  return '<span class="zq-stock-badge zq-stock-in">'+qty+' in stock</span>';
}
function changeLabel(curr,prev){
  if(curr===0&&(!prev||prev===0))return '';
  if(!prev||prev===0)return curr>0?'<span class="zq-change-up">▲ New</span>':'';
  const pct=Math.round((curr-prev)/Math.abs(prev)*100);
  if(pct===0)return '<span class="zq-change-flat">Same as last month</span>';
  if(pct>0)return '<span class="zq-change-up">▲ '+pct+'% vs last month</span>';
  return '<span class="zq-change-down">▼ '+Math.abs(pct)+'% vs last month</span>';
}
function getPOStatus(po){
  const lines=po.lineItems||[];if(!lines.length)return 'ordered';
  const total=lines.reduce((s,l)=>s+(l.qty||0),0);
  const recv=lines.reduce((s,l)=>s+(l.received||0),0);
  if(recv===0)return 'ordered';if(recv>=total)return 'complete';return 'partial';
}
function getPOOutstanding(po){
  if(getPOStatus(po)==='complete')return {};
  const out={};
  (po.lineItems||[]).forEach(l=>{const o=(l.qty||0)-(l.received||0);if(o>0)out[String(l.variantId)]=(out[String(l.variantId)]||0)+o;});
  return out;
}
function buildPOTotals(){
  const totals={};
  purchaseOrders.forEach(po=>{Object.entries(getPOOutstanding(po)).forEach(([vid,qty])=>{totals[vid]=(totals[vid]||0)+qty;});});
  return totals;
}
