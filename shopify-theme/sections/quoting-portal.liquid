document.addEventListener('click',async function(e){
  // Handle order detail link clicks
  const orderLink=e.target.closest('[data-order-detail]');
  if(orderLink){e.preventDefault();toggleOrderDetail(orderLink.dataset.orderDetail);return;}

  const btn=e.target.closest('button');
  if(!btn){
    const header=e.target.closest('.zq-quote-header');
    if(header&&header.dataset.toggle){document.getElementById(header.dataset.toggle)?.classList.toggle('open');return;}
    const poHeader=e.target.closest('.zq-po-header');
    if(poHeader&&poHeader.dataset.poToggle){document.getElementById('po-body-'+poHeader.dataset.poToggle)?.classList.toggle('open');}
    return;
  }
  if(btn.id==='zq-login-btn'){zqLogin();return;}
  if(btn.id==='zq-otp-verify-btn'){zqVerifyOTP();return;}
  if(btn.id==='zq-otp-back-btn'){zqShow('zq-login-screen');return;}
  if(btn.id==='zq-logout-btn'){currentUser=null;sessionToken=null;localStorage.removeItem('zq_token');localStorage.removeItem('nuvio_portal_token');zqShow('zq-login-screen');return;}
  if(btn.id==='zq-new-quote-btn'){zqOpenQuoteForm('New quote',[],null,0,'',null,null);loadAllProducts();loadInventory();return;}
  if(btn.id==='zq-forecast-btn'){openForecastScreen();return;}
  if(btn.id==='zq-orders-btn'){openOrdersScreen();return;}
  if(btn.id==='zq-orders-back-btn'){zqShowDash();return;}
  if(btn.id==='zq-orders-refresh-btn'){allPortalOrders=[];orderDetailCache={};openOrdersScreen();return;}
  if(btn.dataset.sendInvoice){sendInvoiceEmail(btn.dataset.sendInvoice,btn.dataset.sendEmail,btn.dataset.sendName,btn);return;}
  if(btn.dataset.copyInvoice){navigator.clipboard.writeText(btn.dataset.copyInvoice).then(()=>{const orig=btn.innerHTML;btn.innerHTML='✓ Copied';setTimeout(()=>{btn.innerHTML=orig;},2000);}).catch(()=>{prompt('Copy this link:',btn.dataset.copyInvoice);});return;}
  if(btn.dataset.sendProforma){sendProformaEmail(btn.dataset.sendProforma,btn.dataset.sendProformaEmail,btn.dataset.sendProformaName,btn);return;}
  if(btn.id==='zq-forecast-back-btn'){zqShowDash();return;}
  if(btn.id==='zq-new-po-btn'){openNewPOScreen();loadAllProducts();loadStockSettings();return;}
  if(btn.id==='zq-new-po-back-btn'){zqShow('zq-forecast-screen');switchFcTab('pos');return;}
  if(btn.id==='po-submit-btn'){submitNewPO();return;}
  if(btn.id==='zq-fc-refresh-btn'){inventoryLoaded=false;inventory={};variantToInvItem={};salesCache={};openForecastScreen();return;}
  if(btn.id==='zq-fc-send-alert-btn'){
    btn.textContent='Sending…';btn.disabled=true;
    authFetch(API+'/send-low-stock-alert',{method:'POST'}).then(r=>r.json()).then(d=>{
      btn.textContent=d.ok?'✓ Sent':'Failed';
      setTimeout(()=>{btn.textContent='✉ Send alert now';btn.disabled=false;},3000);
    }).catch(()=>{btn.textContent='Failed';setTimeout(()=>{btn.textContent='✉ Send alert now';btn.disabled=false;},2000);});
    return;
  }
  if(btn.id==='zq-fc-needs-order-btn'){
    fcNeedsOrderOnly=!fcNeedsOrderOnly;
    btn.classList.toggle('zq-btn-primary',fcNeedsOrderOnly);
    btn.textContent=fcNeedsOrderOnly?'✕ Show all':'Order needed only';
    zqRenderForecast();
    return;
  }
  if(btn.id==='zq-search-btn'){currentPage=1;zqRenderList();return;}
  if(btn.id==='zq-form-back-btn'){zqShowDash();return;}
  if(btn.id==='zq-costs-back-btn'){zqShowDash();return;}
  if(btn.id==='zq-send-back-btn'){zqShowDash();return;}
  if(btn.id==='zq-succ-back-btn'){zqShowDash();return;}
  if(btn.id==='zq-send-cancel-btn'){zqShowDash();return;}
  if(btn.id==='nq-submit-btn'){zqSubmitQuote();return;}
  if(btn.id==='nq-account-btn'){zqChargeToAccount();return;}
