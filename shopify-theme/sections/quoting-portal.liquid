function submitNewPO(){
  const supplier=document.getElementById('po-supplier')?.value.trim()||'';
  if(!supplier){document.getElementById('po-err').textContent='Please enter a supplier name.';document.getElementById('po-err').style.display='block';return;}
  if(!newPOItems.length){document.getElementById('po-err').textContent='Please add at least one product.';document.getElementById('po-err').style.display='block';return;}
  // MOQ check — total qty of all items must meet supplier MOQ
  const vk=supplier.replace(/[^a-z0-9]/gi,'_');
  const vendorMoq=parseInt(stockSettings['vendor_moq_'+vk])||0;
  if(vendorMoq>0){
    const totalQty=newPOItems.reduce((sum,i)=>sum+(parseInt(i.qty)||0),0);
    if(totalQty<vendorMoq){
      document.getElementById('po-err').textContent='Total order quantity ('+totalQty+') is below the minimum order quantity of '+vendorMoq+' for '+supplier+'.';
      document.getElementById('po-err').style.display='block';
      return;
    }
  }
  if(editingPOId){
    const po=purchaseOrders.find(p=>p.id===editingPOId);
    if(po){
      po.supplier=supplier;
      po.ref=document.getElementById('po-ref')?.value.trim()||'';
      po.arrival=document.getElementById('po-arrival')?.value||'';
      po.notes=document.getElementById('po-notes')?.value.trim()||'';
      po.lineItems=newPOItems.map(i=>({variantId:i.variantId,name:i.name,sku:i.sku||'',image:i.image||'',qty:i.qty,received:i.received||0}));
    }
    editingPOId=null;
  }else{
    const po={id:poNextId(),supplier,ref:document.getElementById('po-ref')?.value.trim()||'',arrival:document.getElementById('po-arrival')?.value||'',notes:document.getElementById('po-notes')?.value.trim()||'',createdAt:today(),lineItems:newPOItems.map(i=>({variantId:i.variantId,name:i.name,sku:i.sku||'',image:i.image||'',qty:i.qty,received:0}))};
    purchaseOrders.push(po);
  }
  savePOs();zqShow('zq-forecast-screen');switchFcTab('pos');renderPOList();zqRenderForecast();
}
