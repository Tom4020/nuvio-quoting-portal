function handleCustSearch(val){
  const res=document.getElementById('nq-cust-results');if(!val||val.length<2){res.style.display='none';return;}
  clearTimeout(custTimer);
  custTimer=setTimeout(async()=>{
    res.innerHTML='<div class="zq-cust-result" style="color:var(--ink-4);font-size:13px;">Searching…</div>';res.style.display='block';
    try{
      const r=await authFetch(API+'/customers?q='+encodeURIComponent(val));const data=await r.json();
      if(!data.length){res.innerHTML='<div class="zq-cust-result" style="color:var(--ink-4);font-size:13px;">No customers found</div>';return;}
      res.innerHTML='';
      data.forEach(c=>{const item=document.createElement('div');item.className='zq-cust-result';item.innerHTML='<div style="font-size:13px;font-weight:500;">'+c.name+'</div><div style="font-size:12px;color:var(--ink-4);">'+c.email+(c.company?' · '+c.company:'')+'</div>';item.addEventListener('click',()=>{document.getElementById('nq-name').value=c.name;document.getElementById('nq-email').value=c.email;document.getElementById('nq-phone').value=c.phone;document.getElementById('nq-company').value=c.company;document.getElementById('nq-address').value=c.address;document.getElementById('nq-cust-search').value='';res.style.display='none';checkAccountCustomer(c.email);});res.appendChild(item);});
    }catch(e){res.innerHTML='<div class="zq-cust-result" style="color:var(--ink-4);font-size:13px;">Search unavailable</div>';}
  },400);
}
function handleProductSearch(val){
  const res=document.getElementById('nq-search-results');if(!val||val.length<2){res.style.display='none';return;}
  clearTimeout(searchTimer);
  searchTimer=setTimeout(()=>{
    if(!productsLoaded){res.innerHTML='<div class="zq-search-item" style="color:var(--ink-4);">Loading products…</div>';res.style.display='block';return;}
    const search=val.toLowerCase();
    const words=search.split(/\s+/).filter(Boolean);
    const matches=[];
    allProducts.forEach(p=>{(p.variants||[]).forEach(v=>{
      const name=(p.productTitle+(v.title!=='Default Title'?' — '+v.title:'')).toLowerCase();
      const sku=(v.sku||'').toLowerCase();
      if(words.every(w=>name.includes(w)||sku.includes(w)))
        matches.push({name:p.productTitle+(v.title!=='Default Title'?' — '+v.title:''),rrp:v.price,image:p.image,handle:p.handle,variantId:v.id,sku:v.sku||''});
    });});
    const top=matches.slice(0,20);if(!top.length){res.innerHTML='<div class="zq-search-item" style="color:var(--ink-4);">No products found</div>';res.style.display='block';return;}
    res.innerHTML='';
    const selected=new Set();
    function renderItems(){
      // Clear existing items (keep confirm bar if present)
      Array.from(res.children).forEach(c=>{if(!c.classList.contains('zq-search-confirm'))c.remove();});
      top.forEach(p=>{
        const vid=String(p.variantId);
        const isSelected=selected.has(vid);
        const item=document.createElement('div');
        item.className='zq-search-item'+(isSelected?' selected':'');
        item.innerHTML=(p.image?'<img src="'+p.image+'" class="zq-search-thumb" />':'<div class="zq-search-thumb"></div>')
          +'<span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:500;">'+p.name+'</span>'
          +stockBadge(vid)
          +'<span style="color:var(--ink-4);font-size:12px;flex-shrink:0;margin-left:6px;">'+fmt(p.rrp)+'</span>'
          +'<span class="zq-search-check" style="margin-left:8px;">'+(isSelected?'✓':'✓')+'</span>';
        item.addEventListener('click',(e)=>{
          e.stopPropagation();
          if(selected.has(vid)){selected.delete(vid);}else{selected.add(vid);}
          updateConfirmBar();
          renderItems();
        });
        // Insert before confirm bar
        const bar=res.querySelector('.zq-search-confirm');
        if(bar){res.insertBefore(item,bar);}else{res.appendChild(item);}
      });
    }
    function updateConfirmBar(){
      let bar=res.querySelector('.zq-search-confirm');
      if(!bar){bar=document.createElement('div');bar.className='zq-search-confirm';res.appendChild(bar);}
      const count=selected.size;
      bar.innerHTML='<span style="font-size:12px;color:var(--ink-3);">'+(count?count+' selected':'Click items to select')+'</span>'
        +(count?'<button class="zq-btn zq-btn-primary zq-btn-sm" id="nq-search-add-btn">Add '+count+' item'+(count>1?'s':'')+'</button>':'');
      if(count){
        bar.querySelector('#nq-search-add-btn').addEventListener('click',(e)=>{
          e.stopPropagation();
          const d=isAdmin()?(parseFloat(document.getElementById('nq-discount').value)||0):parseInt(document.querySelector('#nq-disc-staff .zq-disc-btn.active')?.dataset.disc||'0')||0;
          top.filter(p=>selected.has(String(p.variantId))).forEach(p=>{
            const ex=newQuoteItems.find(i=>i.variantId===p.variantId);
            if(ex){ex.qty++;}else{newQuoteItems.push({name:p.name,rrp:parseFloat(p.rrp),image:p.image||'',handle:p.handle||'',variantId:p.variantId,sku:p.sku||'',qty:1,discount:d});}
          });
          zqRenderNewItems();zqUpdateNewMargin();
          document.getElementById('nq-search').value='';res.style.display='none';
        });
      }
    }
    renderItems();
    updateConfirmBar();
    res.style.display='block';
  },300);
}
