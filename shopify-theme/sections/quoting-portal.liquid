  if(!isAdmin()){return '<div class="zq-margin-row"><span>RRP total</span><span style="text-decoration:line-through;color:var(--ink-4);">'+fmt(t.subtotal)+'</span></div><div class="zq-margin-row total"><span>Quote total</span><span>'+fmt(t.discounted)+'</span></div>'+(t.saving>0?'<div class="zq-margin-row saving"><span>Customer saving</span><span>−'+fmt(t.saving)+'</span></div>':'')+commLine;}
  return '<div class="zq-margin-row"><span>Subtotal (RRP)</span><span>'+fmt(t.subtotal)+'</span></div><div class="zq-margin-row"><span>After discounts</span><span>'+fmt(t.discounted)+'</span></div><div class="zq-margin-row"><span>Total cost</span><span>'+fmt(t.cost)+'</span></div><div class="zq-margin-row total profit"><span>Margin</span><span>'+fmt(t.margin)+' ('+t.marginPct.toFixed(1)+'%)</span></div>'+(t.saving>0?'<div class="zq-margin-row saving"><span>Customer saving</span><span>−'+fmt(t.saving)+'</span></div>':'')+commLine;
