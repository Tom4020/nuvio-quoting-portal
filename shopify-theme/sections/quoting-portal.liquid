async function toggleOrderDetail(orderId){
  const row=document.getElementById('zq-order-detail-'+orderId);
  if(!row) return;
  // Toggle visibility
  if(row.style.display!=='none'){
    row.style.display='none';
    return;
  }
  row.style.display='table-row';
  const content=document.getElementById('zq-order-detail-content-'+orderId);

  // Check cache
  if(orderDetailCache[orderId]){
    renderOrderDetail(content,orderDetailCache[orderId]);
    return;
  }

  content.innerHTML='<div style="font-size:13px;color:var(--ink-4);">Loading order details…</div>';
  try{
    const r=await authFetch(API+'/admin/order-detail/'+orderId);
    const data=await r.json();
    orderDetailCache[orderId]=data;
    renderOrderDetail(content,data);
  }catch(e){
    content.innerHTML='<div style="font-size:13px;color:var(--danger);">Failed to load details.</div>';
  }
}

function renderOrderDetail(el,data){
  const fmtD=v=>'$'+parseFloat(v||0).toFixed(2);
  let html='';

  // ── Line items table ──
  html+='<p style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-4);margin:0 0 8px;">Line items</p>';
  html+='<table style="width:100%;border-collapse:collapse;font-size:12px;margin-bottom:14px;">';
  html+='<thead><tr style="border-bottom:1px solid var(--rule);">';
  html+='<th style="text-align:left;padding:6px 8px;font-size:10px;font-weight:600;text-transform:uppercase;color:var(--ink-4);">Product</th>';
  html+='<th style="text-align:center;padding:6px 8px;font-size:10px;font-weight:600;text-transform:uppercase;color:var(--ink-4);">Qty</th>';
  html+='<th style="text-align:center;padding:6px 8px;font-size:10px;font-weight:600;text-transform:uppercase;color:var(--ink-4);">Fulfilled</th>';
  html+='<th style="text-align:center;padding:6px 8px;font-size:10px;font-weight:600;text-transform:uppercase;color:var(--ink-4);">Unfulfilled</th>';
  html+='<th style="text-align:right;padding:6px 8px;font-size:10px;font-weight:600;text-transform:uppercase;color:var(--ink-4);">Price</th>';
  html+='<th style="text-align:left;padding:6px 8px;font-size:10px;font-weight:600;text-transform:uppercase;color:var(--ink-4);">Tracking</th>';
  html+='</tr></thead><tbody>';

  (data.items||[]).forEach(item=>{
    const fulfilledColor=item.fulfilledQty>=item.quantity?'#22863a':item.fulfilledQty>0?'#d29922':'#6a737d';
    const unfulfilledColor=item.unfulfilled>0?'#cb2431':'#22863a';
    let trackingHtml='—';
    if(item.tracking&&item.tracking.length){
      trackingHtml=item.tracking.map(t=>{
        if(t.url) return '<a href="'+t.url+'" target="_blank" style="color:var(--accent);text-decoration:none;font-size:11px;">'+t.number+(t.company?' ('+t.company+')':'')+'</a>';
        return '<span style="font-size:11px;">'+t.number+(t.company?' ('+t.company+')':'')+'</span>';
      }).join('<br>');
    }
    html+='<tr style="border-bottom:1px solid var(--rule);">';
    html+='<td style="padding:7px 8px;">'+item.title+(item.variant?'<br><span style="font-size:11px;color:var(--ink-4);">'+item.variant+'</span>':'')+(item.sku?'<br><span style="font-size:10px;color:var(--ink-4);">SKU: '+item.sku+'</span>':'')+'</td>';
    html+='<td style="padding:7px 8px;text-align:center;">'+item.quantity+'</td>';
    html+='<td style="padding:7px 8px;text-align:center;color:'+fulfilledColor+';font-weight:600;">'+item.fulfilledQty+'</td>';
    html+='<td style="padding:7px 8px;text-align:center;color:'+unfulfilledColor+';font-weight:600;">'+item.unfulfilled+'</td>';
    html+='<td style="padding:7px 8px;text-align:right;">'+fmtD(item.price)+'</td>';
    html+='<td style="padding:7px 8px;">'+trackingHtml+'</td>';
    html+='</tr>';
  });
  html+='</tbody></table>';

  // ── Fulfillments summary ──
  if(data.fulfillments&&data.fulfillments.length){
    html+='<p style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-4);margin:0 0 8px;">Shipments</p>';
    data.fulfillments.forEach((f,fi)=>{
      const statusColor=f.status==='success'?'#22863a':f.status==='cancelled'?'#cb2431':'#d29922';
      html+='<div style="background:var(--surface);border:1px solid var(--rule);border-radius:var(--radius);padding:10px 12px;margin-bottom:8px;">';
      html+='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">';
      html+='<span style="font-size:12px;font-weight:600;">Shipment '+(fi+1)+'</span>';
      html+='<span style="font-size:11px;font-weight:600;color:'+statusColor+';text-transform:capitalize;">'+f.status+'</span>';
      html+='</div>';
      if(f.trackingNumber){
        html+='<div style="font-size:12px;margin-bottom:4px;">';
        html+='<span style="color:var(--ink-4);">Tracking:</span> ';
        if(f.trackingUrl) html+='<a href="'+f.trackingUrl+'" target="_blank" style="color:var(--accent);text-decoration:none;">'+f.trackingNumber+'</a>';
        else html+=f.trackingNumber;
        if(f.trackingCompany) html+=' <span style="color:var(--ink-4);">('+f.trackingCompany+')</span>';
        html+='</div>';
      }
      if(f.items&&f.items.length){
        html+='<div style="font-size:11px;color:var(--ink-4);margin-top:4px;">Items: '+f.items.map(fi=>fi.title+(fi.variant?' — '+fi.variant:'')+' ×'+fi.quantity).join(', ')+'</div>';
      }
      html+='</div>';
    });
  }

  // ── Order note ──
  if(data.note){
    html+='<p style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--ink-4);margin:12px 0 4px;">Order note</p>';
    html+='<p style="font-size:12px;color:var(--ink);margin:0;">'+data.note.replace(/</g,'&lt;').replace(/>/g,'&gt;')+'</p>';
  }

  el.innerHTML=html;
}

