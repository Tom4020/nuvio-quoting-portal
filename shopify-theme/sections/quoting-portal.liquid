async function createProduct(){
  const btn=document.getElementById('zq-prod-save-btn');
  const err=document.getElementById('zq-prod-err');
  const ok=document.getElementById('zq-prod-ok');
  err.style.display='none';ok.style.display='none';
  const title=document.getElementById('zq-prod-title').value.trim();
  if(!title){err.textContent='Title is required.';err.style.display='block';return;}
  btn.textContent='Creating…';btn.disabled=true;
  const payload={
    title,
    body_html:document.getElementById('zq-prod-desc-editor').innerHTML,
    vendor:document.getElementById('zq-prod-vendor').value.trim(),
    product_type:document.getElementById('zq-prod-type').value.trim(),
    tags:document.getElementById('zq-prod-tags').value.trim(),
    status:document.getElementById('zq-prod-new-status').value,
    inventory_quantity:parseInt(document.getElementById('zq-prod-stock').value)||0,
    variants:[{
      price:document.getElementById('zq-prod-price').value||'0',
      compare_at_price:document.getElementById('zq-prod-compare').value||null,
      sku:document.getElementById('zq-prod-sku').value.trim(),
      barcode:document.getElementById('zq-prod-barcode').value.trim(),
      weight:parseFloat(document.getElementById('zq-prod-weight').value)||0,
      weight_unit:'kg',
      inventory_management:'shopify',
    }]
  };
  try{
    const r=await authFetch(API+'/manage-products',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    const d=await r.json();
    if(d.id){
      ok.textContent='Product created! (ID '+d.id+')';ok.style.display='block';
      ['zq-prod-title','zq-prod-vendor','zq-prod-type','zq-prod-tags','zq-prod-sku','zq-prod-price','zq-prod-compare','zq-prod-barcode','zq-prod-weight','zq-prod-stock'].forEach(id=>{document.getElementById(id).value='';});
      document.getElementById('zq-prod-desc-editor').innerHTML='';;
    }else{err.textContent=d.error||'Failed to create product.';err.style.display='block';}
  }catch(e){err.textContent=e.message;err.style.display='block';}
  btn.textContent='Create product in Shopify';btn.disabled=false;
}
