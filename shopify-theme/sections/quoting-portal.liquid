        +'<tbody>'+csvRows.slice(0,10).map(r=>'<tr><td>'+escHtml(r.title)+'</td><td>'+escHtml(r.vendor||'')+'</td><td>'+escHtml(r.product_type||'')+'</td><td>'+escHtml(r.sku||'')+'</td><td>'+escHtml(r.price||'')+'</td><td>'+escHtml(r.status||'')+'</td></tr>').join('')
        +(csvRows.length>10?'<tr><td colspan="6" style="color:var(--ink-4);font-style:italic;">… and '+(csvRows.length-10)+' more</td></tr>':'')
        +'</tbody>';
      document.getElementById('zq-csv-preview').style.display='block';
    };
