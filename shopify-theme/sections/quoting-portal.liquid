      const res=await authFetch(API+'/receive-po',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({poId,lines})});
      const data=await res.json();
      if(data.ok){po.lineItems.forEach((line,idx)=>{line.received=lines[idx].newReceived;});data.results.forEach(r=>{if(r.ok&&!r.skipped&&r.newAvailable!==undefined){inventory[String(r.variantId)]=r.newAvailable;}});renderPOList();zqRenderForecast();btn.textContent='Saved ✓';setTimeout(()=>{btn.textContent='Save received quantities';btn.disabled=false;},2000);}
      else{alert('Error: '+(data.error||'Unknown'));btn.textContent='Save received quantities';btn.disabled=false;}
    }catch(err){alert('Connection error: '+err.message);btn.textContent='Save received quantities';btn.disabled=false;}
    return;
  }
  if(btn.dataset.deletePo){if(!confirm('Delete this purchase order?'))return;purchaseOrders=purchaseOrders.filter(p=>p.id!==btn.dataset.deletePo);savePOs();renderPOList();zqRenderForecast();return;}
  if(btn.dataset.pdfPo){downloadPOPdf(btn.dataset.pdfPo);return;}
  if(btn.dataset.editPo){openEditPOScreen(btn.dataset.editPo);loadAllProducts();return;}
  if(btn.dataset.poQtyIdx!==undefined){const idx=parseInt(btn.dataset.poQtyIdx);newPOItems[idx].qty=Math.max(1,newPOItems[idx].qty+parseInt(btn.dataset.poQtyDelta));const inp=document.querySelector('input[data-po-qty-direct="'+idx+'"]');if(inp)inp.value=newPOItems[idx].qty;renderPOItems();return;}
  if(btn.dataset.poRemoveIdx!==undefined){newPOItems.splice(parseInt(btn.dataset.poRemoveIdx),1);renderPOItems();return;}
  if(btn.dataset.filter!==undefined){currentFilter=btn.dataset.filter;currentPage=1;document.querySelectorAll('.zq-tab').forEach(t=>t.classList.remove('active'));btn.classList.add('active');zqRenderList();return;}
  if(btn.dataset.send){zqOpenSend(btn.dataset.send);return;}
  if(btn.dataset.edit){const q=quotes.find(x=>x.id===btn.dataset.edit);zqOpenQuoteForm('Edit quote — '+q.id,q.items,q.customer,q.items.length?(q.items[0].discount||0):0,q.notes,q.id,q.expiry,q.projectName);loadAllProducts();return;}
  if(btn.dataset.convert){quotes.find(x=>x.id===btn.dataset.convert).status='converted';saveQuotes();zqRenderDash();return;}
  if(btn.dataset.decline){quotes.find(x=>x.id===btn.dataset.decline).status='declined';saveQuotes();zqRenderDash();return;}
  if(btn.dataset.delete){if(!confirm('Delete quote '+btn.dataset.delete+'?'))return;quotes=quotes.filter(x=>x.id!==btn.dataset.delete);saveQuotes();zqRenderDash();return;}
  if(btn.dataset.saveExpiry){const inp=document.querySelector('input[data-id="'+btn.dataset.saveExpiry+'"]');if(inp&&inp.value){const q=quotes.find(x=>x.id===btn.dataset.saveExpiry);if(q){q.expiry=inputToDate(inp.value);saveQuotes();zqRenderDash();}}return;}
  if(btn.dataset.qtyIdx!==undefined){const idx=parseInt(btn.dataset.qtyIdx);newQuoteItems[idx].qty=Math.max(1,newQuoteItems[idx].qty+parseInt(btn.dataset.qtyDelta));const inp=document.querySelector('input[data-qty-direct="'+idx+'"]');if(inp)inp.value=newQuoteItems[idx].qty;zqRenderNewItems();zqUpdateNewMargin();return;}
  if(btn.dataset.removeIdx!==undefined){newQuoteItems.splice(parseInt(btn.dataset.removeIdx),1);zqRenderNewItems();zqUpdateNewMargin();return;}
  if(btn.dataset.disc!==undefined&&btn.closest('#nq-disc-staff')){document.querySelectorAll('#nq-disc-staff .zq-disc-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');const pct=parseInt(btn.dataset.disc);newQuoteItems.forEach(i=>i.discount=pct);zqRenderNewItems();zqUpdateNewMargin();return;}
  if(btn.id==='zq-products-back-btn'){zqShowDash();return;}
  if(btn.id==='zq-prod-save-btn'){createProduct();return;}
  if(btn.id==='zq-csv-template-btn'){downloadCsvTemplate();return;}
  if(btn.id==='zq-csv-import-btn'){importCsvProducts();return;}
  if(btn.dataset.prodTab){switchProdTab(btn.dataset.prodTab);return;}
  if(btn.dataset.editProduct){const panel=document.getElementById('zq-edit-prod-'+btn.dataset.editProduct);if(panel)panel.style.display=panel.style.display==='none'?'block':'none';return;}
  if(btn.dataset.cancelEdit){const panel=document.getElementById('zq-edit-prod-'+btn.dataset.cancelEdit);if(panel)panel.style.display='none';return;}
  if(btn.dataset.saveProduct){saveProductEdit(btn.dataset.saveProduct,btn.dataset.variantId);return;}
  if(btn.dataset.deleteProduct){
    if(!confirm('Delete "'+btn.dataset.productTitle+'"? This cannot be undone.'))return;
    authFetch(API+'/manage-products/'+btn.dataset.deleteProduct,{method:'DELETE'}).then(()=>{allManageProducts=allManageProducts.filter(p=>String(p.id)!==String(btn.dataset.deleteProduct));renderManageProducts();});return;
  }
  if(btn.dataset.delImg){deleteProductImage(btn.dataset.prodId,btn.dataset.delImg);return;}
});
document.addEventListener('input',function(e){
  const t=e.target;
  if(t.id==='zq-otp-code'){
    // Strip non-digits
    t.value=t.value.replace(/\D/g,'');
    if(t.value.length===6)zqVerifyOTP();
    return;
  }
  if(t.id==='zq-prod-search'){
    clearTimeout(prodSearchTimer);
    prodSearchTimer=setTimeout(()=>renderManageProducts(),200);
    return;
  }
  if(t.id==='zq-prod-status-filter'){allManageProducts=[];fetchManageProducts();return;}
  if(t.id==='nq-cust-search'){handleCustSearch(t.value);return;}
  if(t.id==='nq-search'){handleProductSearch(t.value);return;}
  if(t.id==='po-search'){handlePOProductSearch(t.value);return;}
  if(t.id==='nq-discount'&&isAdmin()){const d=parseFloat(t.value)||0;newQuoteItems.forEach(i=>i.discount=d);zqRenderNewItems();zqUpdateNewMargin();return;}
  if(t.dataset.discIdx!==undefined&&isAdmin()){newQuoteItems[parseInt(t.dataset.discIdx)].discount=parseFloat(t.value)||0;zqRenderNewItems();zqUpdateNewMargin();return;}
  if(t.dataset.qtyDirect!==undefined){const idx=parseInt(t.dataset.qtyDirect);const val=parseInt(t.value);if(!isNaN(val)&&val>=1){newQuoteItems[idx].qty=val;zqUpdateNewMargin();}return;}
  if(t.dataset.poQtyDirect!==undefined){const idx=parseInt(t.dataset.poQtyDirect);const val=parseInt(t.value);if(!isNaN(val)&&val>=1){newPOItems[idx].qty=val;}return;}
  if(t.dataset.costId!==undefined){
    const vid=String(t.dataset.costId);
    const existing=getCostData(vid);
    costs[vid]={price:parseFloat(t.value)||0,supplierCode:existing.supplierCode,landedUSD:existing.landedUSD,supplierName:existing.supplierName};
    debounceSaveCosts();
    return;
  }
  if(t.dataset.supplierNameId!==undefined){
    const vid=String(t.dataset.supplierNameId);
    const existing=getCostData(vid);
    costs[vid]={price:existing.price,supplierCode:existing.supplierCode,landedUSD:existing.landedUSD,supplierName:t.value.trim()};
    debounceSaveCosts();
    zqRenderForecast(); // refresh stock levels grouping live
    return;
  }
  if(t.dataset.supplierCodeId!==undefined){
    const vid=String(t.dataset.supplierCodeId);
    const existing=getCostData(vid);
    costs[vid]={price:existing.price,supplierCode:t.value.trim(),landedUSD:existing.landedUSD,supplierName:existing.supplierName};
    debounceSaveCosts();
    return;
  }
  if(t.dataset.landedUsdId!==undefined){
    const vid=String(t.dataset.landedUsdId);
    const existing=getCostData(vid);
    costs[vid]={price:existing.price,supplierCode:existing.supplierCode,landedUSD:parseFloat(t.value)||0,supplierName:existing.supplierName};
    debounceSaveCosts();
    return;
  }
  if(t.id==='calc-search'){zqRenderCalcList(t.value);return;}
  if(t.id==='calc-audusd'){
    const rate=parseFloat(t.value)||0;
    calcData.audUsd=rate;
    const d=document.getElementById('calc-audusd-display');
    if(d)d.textContent=rate?rate.toFixed(4):'—';
    // Re-render all AUD totals
    allProducts.forEach(p=>{(p.variants||[]).forEach(v=>zqUpdateCalcRow(String(v.id)));});
    return;
  }
  if(t.dataset.calcPackaging!==undefined){
    const vid=String(t.dataset.calcPackaging);
    if(!calcData[vid])calcData[vid]={};
    calcData[vid].packaging=parseFloat(t.value)||0;
    zqUpdateCalcRow(vid);
    return;
  }
  if(t.dataset.calcFreight!==undefined){
    const vid=String(t.dataset.calcFreight);
    if(!calcData[vid])calcData[vid]={};
    calcData[vid].freight=parseFloat(t.value)||0;
    zqUpdateCalcRow(vid);
    return;
  }
  if(t.dataset.calcLocalPackaging!==undefined){
    const vid=String(t.dataset.calcLocalPackaging);
    if(!calcData[vid])calcData[vid]={};
    calcData[vid].localPackaging=parseFloat(t.value)||0;
    zqUpdateCalcRow(vid);
    return;
  }
  if(t.dataset.ssThreshold!==undefined){
    const vid=String(t.dataset.ssThreshold);
    if(!stockSettings[vid])stockSettings[vid]={};
    stockSettings[vid].threshold=parseInt(t.value)||0;
    stockSettings[vid].name=t.dataset.ssName||'';
    stockSettings[vid].sku=t.dataset.ssSku||'';
    saveStockSettings();
    return;
  }
  if(t.dataset.vendorMoq!==undefined){
    const vk=t.dataset.vendorMoq;
    const val=parseInt(t.value)||0;
    if(val>0){stockSettings['vendor_moq_'+vk]=val;}else{delete stockSettings['vendor_moq_'+vk];}
    saveStockSettings();
    return;
  }
  if(t.dataset.ssMoq!==undefined){
    const vid=String(t.dataset.ssMoq);
    if(!stockSettings[vid])stockSettings[vid]={};
    stockSettings[vid].moq=parseInt(t.value)||0;
    saveStockSettings();
    return;
  }
  if(t.dataset.leadTimeVendor!==undefined){
    const vendor=t.dataset.leadTimeVendor;
    const weeks=parseInt(t.value)||0;
    if(weeks>0){leadTimes[vendor]=weeks;}else{delete leadTimes[vendor];}
    saveLeadTimes();
    if(weeks>0){
      // Delete cache for this week count so it re-fetches fresh
      delete salesCache[weeks];
      loadSalesData(weeks).then(()=>{
        zqRenderForecast();
      });
    }else{
      zqRenderForecast();
    }
    return;
  }
  if(t.dataset.newOrderVid!==undefined){
    const qty=parseInt(t.value)||0;
    const moq=parseInt(t.dataset.newOrderMoq)||0;
    const errEl=document.getElementById('moq-err-'+t.dataset.newOrderVid);
    const isBelowMoq=moq>0&&qty>0&&qty<moq;
    t.style.borderColor=isBelowMoq?'var(--danger)':'';
    t.style.background=isBelowMoq?'#fff5f5':'';
    if(errEl)errEl.style.display=isBelowMoq?'block':'none';
    if(qty>0){newOrderQtys[t.dataset.newOrderVid]=qty;}
    else{delete newOrderQtys[t.dataset.newOrderVid];}
    return;
  }
});
document.addEventListener('change',function(e){
