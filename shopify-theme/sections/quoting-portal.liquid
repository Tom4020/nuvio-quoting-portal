  if(t.dataset.notesId){const q=quotes.find(x=>x.id===t.dataset.notesId);if(q){q.notes=t.value;saveQuotes();}}
  if(t.dataset.assignSp!==undefined&&isAdmin()){const q=quotes.find(x=>x.id===t.dataset.assignSp);if(q){q.salesperson=t.value||null;saveQuotes();zqRenderList();}}
  if(t.id==='zq-comm-month-sel'){renderCommissionBox();}
