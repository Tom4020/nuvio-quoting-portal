async function verifySupplierInvoice(poId, file){
  const po=purchaseOrders.find(p=>p.id===poId);
  if(!po)return;
  const panel=document.getElementById('po-verify-'+poId);
  panel.style.display='block';
  panel.innerHTML='<div style="background:var(--surface-2);border:1px solid var(--rule);border-radius:var(--radius);padding:20px;"><p style="font-size:13px;color:var(--ink-4);">📄 Reading invoice with AI… large invoices may take 10–20 seconds</p></div>';
  // Read file as base64
  const base64=await new Promise((res,rej)=>{
    const reader=new FileReader();
    reader.onload=()=>res(reader.result.split(',')[1]);
    reader.onerror=()=>rej(new Error('Failed to read file'));
    reader.readAsDataURL(file);
  });
  // Build PO summary for Claude
  const poSummary=po.lineItems.map(l=>{
    const cd=getCostData(l.variantId);
    const usd=parseFloat(cd.landedUSD)||0;
    return `- ${l.name} (SKU: ${l.sku||'?'}) — qty: ${l.qty}${usd?' — our unit price: $'+usd.toFixed(2)+' USD':''}`;
  }).join('\n');
  // Determine media type
  const isPDF=file.type==='application/pdf'||file.name.toLowerCase().endsWith('.pdf');
  const mediaType=isPDF?'application/pdf':(file.type||'image/jpeg');
  const prompt=`You are checking a supplier invoice or packing list against a purchase order. You must respond with valid JSON only — no explanation, no markdown, no code blocks, just the raw JSON object.
PURCHASE ORDER: ${po.id}
Supplier: ${po.supplier}
Reference: ${po.ref||'—'}
ITEMS ORDERED (with our expected unit prices in USD):
${poSummary}
Carefully read every line of the attached document. Extract ALL line items including their quantities and unit prices. Then compare each PO item against what you found.
Important rules:
- Never return qty: 0 for an item you actually found in the document — use the real quantity shown
- Never return unitPrice: 0 for an item with a visible price — use the real price shown
- Only use status "missing_from_invoice" if the item truly cannot be found anywhere in the document
- Match items by SKU code first, then by product name similarity
- Price tolerance: treat prices within $0.02 as matching
Respond with this exact JSON structure and nothing else:
{"invoiceNumber":null,"invoiceDate":null,"extractedItems":[{"name":"product name","sku":"code or null","qty":0,"unitPrice":null}],"matches":[{"poItem":"item name from PO","poQty":0,"invoiceQty":0,"poUnitPrice":0,"invoiceUnitPrice":0,"status":"ok","note":null}],"summary":"one sentence summary"}
Status values: "ok" = qty and price both match, "qty_mismatch" = different quantities, "price_mismatch" = different unit price, "qty_price_mismatch" = both wrong, "missing_from_invoice" = truly not found in document, "extra_on_invoice" = in document but not on PO.`;
  try{
    const response=await authFetch(API+'/claude-proxy',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:4000,
        messages:[{
          role:'user',
          content:[
            isPDF
              ?{type:'document',source:{type:'base64',media_type:'application/pdf',data:base64}}
              :{type:'image',source:{type:'base64',media_type:mediaType,data:base64}},
            {type:'text',text:prompt}
          ]
        }]
      })
    });
    const data=await response.json();
    const text=data.content?.map(c=>c.text||'').join('').trim();
    console.log('Claude invoice response:',text);
    // If proxy returned an error
    if(data.error){
      panel.innerHTML='<div style="background:var(--danger-bg);border:1px solid #e8c8c6;border-radius:var(--radius);padding:16px;font-size:13px;color:var(--danger);">Server error: '+data.error+'</div>';
      return;
    }
    let result;
    try{
      const cleaned=text.replace(/^```json\s*/,'').replace(/^```\s*/,'').replace(/\s*```$/,'').trim();
      result=JSON.parse(cleaned);
    }catch(e){
      panel.innerHTML='<div style="background:var(--danger-bg);border:1px solid #e8c8c6;border-radius:var(--radius);padding:16px;font-size:13px;color:var(--danger);">Could not parse AI response.<br><details style="margin-top:8px;"><summary style="cursor:pointer;font-size:12px;">Show raw response</summary><pre style="font-size:11px;margin-top:8px;white-space:pre-wrap;color:var(--ink-3);">'+(text||JSON.stringify(data))+'</pre></details></div>';
      return;
    }
    // If matches missing, build from extractedItems vs PO lines
    if(!result.matches||!result.matches.length){
      result.matches=po.lineItems.map(line=>{
        const cd=getCostData(line.variantId);
        const poPrice=parseFloat(cd.landedUSD)||0;
        const found=(result.extractedItems||[]).find(i=>
          (i.sku&&line.sku&&i.sku.toLowerCase()===line.sku.toLowerCase())||
          (i.name&&line.name&&i.name.toLowerCase().includes(line.name.split(' — ')[0].toLowerCase().substring(0,10)))
        );
        if(!found)return{poItem:line.name,poQty:line.qty,invoiceQty:null,poUnitPrice:poPrice||null,invoiceUnitPrice:null,status:'missing_from_invoice',note:null};
        const qtyOk=found.qty===line.qty;
        const priceOk=!poPrice||!found.unitPrice||Math.abs(found.unitPrice-poPrice)<0.02;
        const status=qtyOk&&priceOk?'ok':!qtyOk&&!priceOk?'qty_price_mismatch':!qtyOk?'qty_mismatch':'price_mismatch';
        return{poItem:line.name,poQty:line.qty,invoiceQty:found.qty,poUnitPrice:poPrice||null,invoiceUnitPrice:found.unitPrice||null,status,note:null};
      });
    }
    const statusIcon={ok:'✅',qty_mismatch:'⚠️',price_mismatch:'⚠️',qty_price_mismatch:'❌',missing_from_invoice:'❌',extra_on_invoice:'➕'};
    const statusColor={ok:'var(--success)',qty_mismatch:'var(--warning)',price_mismatch:'var(--warning)',qty_price_mismatch:'var(--danger)',missing_from_invoice:'var(--danger)',extra_on_invoice:'var(--info)'};
    const statusLabel={ok:'Match',qty_mismatch:'Qty mismatch',price_mismatch:'Price mismatch',qty_price_mismatch:'Qty & price mismatch',missing_from_invoice:'Missing from invoice',extra_on_invoice:'Not on PO'};
    const allOk=result.matches&&result.matches.every(m=>m.status==='ok');
    const issues=result.matches?result.matches.filter(m=>m.status!=='ok'):[];
    const th='<th style="padding:8px 12px;text-align:center;font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-4);">';
    let html='<div style="background:var(--surface);border:1px solid var(--rule);border-radius:var(--radius-lg);overflow:hidden;">'
      +'<div style="padding:16px 20px;background:'+(allOk?'var(--success-bg)':'var(--warning-bg)')+';border-bottom:1px solid var(--rule);display:flex;align-items:center;gap:10px;">'
        +'<span style="font-size:18px;">'+(allOk?'✅':'⚠️')+'</span>'
        +'<div>'
          +'<div style="font-size:13px;font-weight:600;color:'+(allOk?'var(--success)':'var(--warning)')+';">'+(allOk?'Invoice matches PO':issues.length+' issue'+(issues.length!==1?'s':'')+' found')+'</div>'
          +(result.summary?'<div style="font-size:12px;color:var(--ink-3);margin-top:2px;">'+result.summary+'</div>':'')
        +'</div>'
        +(result.invoiceNumber?'<div style="margin-left:auto;text-align:right;"><div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--ink-4);">Invoice</div><div style="font-size:13px;font-weight:600;">'+result.invoiceNumber+'</div></div>':'')
      +'</div>'
      +'<table style="width:100%;border-collapse:collapse;font-size:13px;">'
        +'<thead><tr style="background:var(--surface-2);">'
          +'<th style="padding:8px 12px;text-align:left;font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-4);">Item</th>'
          +th+'PO qty</th>'
          +th+'Invoice qty</th>'
          +th+'Our price USD</th>'
          +th+'Invoice price USD</th>'
          +'<th style="padding:8px 12px;text-align:left;font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-4);">Status</th>'
        +'</tr></thead><tbody>';
    (result.matches||[]).forEach((m,i)=>{
      const bg=i%2===0?'var(--surface)':'var(--surface-2)';
      // Treat invoiceQty of 0 or null as effectively missing
      const effectivelyMissing=m.status==='missing_from_invoice'||(m.invoiceQty!=null&&m.invoiceQty===0&&!m.invoiceUnitPrice);
      const effectiveStatus=effectivelyMissing?'missing_from_invoice':m.status;
      const sc=statusColor[effectiveStatus]||'var(--ink)';
      const qtyMismatch=effectiveStatus==='qty_mismatch'||effectiveStatus==='qty_price_mismatch';
      const priceMismatch=(effectiveStatus==='price_mismatch'||effectiveStatus==='qty_price_mismatch')&&m.invoiceUnitPrice>0;
      const fmtUSD=v=>v!=null&&v>0?'$'+parseFloat(v).toFixed(2):'—';
      html+='<tr style="background:'+bg+';">'
        +'<td style="padding:10px 12px;font-weight:500;">'+m.poItem+(m.note?'<div style="font-size:11px;color:var(--ink-4);margin-top:2px;">'+m.note+'</div>':'')+'</td>'
        +'<td style="padding:10px 12px;text-align:center;">'+(m.poQty??'—')+'</td>'
        +'<td style="padding:10px 12px;text-align:center;font-weight:600;color:'+(qtyMismatch?'var(--danger)':'var(--ink)')+';">'+(effectivelyMissing?'—':(m.invoiceQty??'—'))+'</td>'
        +'<td style="padding:10px 12px;text-align:center;color:var(--ink-3);">'+fmtUSD(m.poUnitPrice)+'</td>'
        +'<td style="padding:10px 12px;text-align:center;font-weight:600;color:'+(priceMismatch?'var(--danger)':'var(--ink)')+';">'+fmtUSD(m.invoiceUnitPrice)+'</td>'
        +'<td style="padding:10px 12px;"><span style="color:'+sc+';font-weight:600;font-size:12px;">'+statusIcon[effectiveStatus]+' '+statusLabel[effectiveStatus]+'</span></td>'
        +'</tr>';
    });
    html+='</tbody></table></div>';
    panel.innerHTML=html;
  }catch(e){
    panel.innerHTML='<div style="background:var(--danger-bg);border:1px solid #e8c8c6;border-radius:var(--radius);padding:16px;font-size:13px;color:var(--danger);">Error: '+e.message+'</div>';
  }
}
// Auto-restore session on page load
(async function init(){
  const savedToken=localStorage.getItem('zq_token');
  if(savedToken){
    sessionToken=savedToken;
    try{
      const r=await authFetch(API+'/users');
      if(r.status===401)throw new Error('expired');
      const users=await r.json();
      if(Array.isArray(users)&&users.length){USERS=users;localStorage.setItem('zq_users',JSON.stringify(USERS));}
      const payload=JSON.parse(atob(savedToken.split('.')[0]));
      currentUser={email:payload.email,name:payload.name,role:payload.role,commission:0};
      const u=USERS.find(u=>u.email===payload.email);
      if(u)currentUser.commission=u.commission||0;
      document.getElementById('zq-user-label').textContent=currentUser.name+' · '+currentUser.role;
      document.getElementById('zq-forecast-btn').style.display=currentUser.role==='admin'?'inline-flex':'none';
      document.getElementById('zq-orders-btn').style.display='inline-flex';
      const prodBtn=document.getElementById('zq-products-btn');if(prodBtn)prodBtn.style.display=currentUser.role==='admin'?'inline-flex':'none';
      populateSpFilter();zqShow('zq-dashboard');setSyncStatus('Loading quotes…');
      await loadQuotesFromRailway();zqRenderDash();
      loadCostsFromRailway().then(()=>loadCostsFromShopify());loadAllProducts();loadInventory();loadPOs();
      return;
    }catch(e){
      sessionToken=null;localStorage.removeItem('zq_token');
    }
  }
  zqShow('zq-login-screen');
})();
})();
</script>
