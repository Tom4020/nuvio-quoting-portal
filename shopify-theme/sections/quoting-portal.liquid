let prodSearchTimer=null;
let allManageProducts=[];
function openProductsScreen(){
  zqShow('zq-products-screen');
  switchProdTab('list');
  allManageProducts=[];
  fetchManageProducts();
}
function switchProdTab(tab){
  ['list','add','csv'].forEach(t=>{
    document.getElementById('zq-prod-'+t+'-tab').style.display=t===tab?'block':'none';
    document.querySelectorAll('[data-prod-tab]').forEach(btn=>btn.classList.toggle('active',btn.dataset.prodTab===tab));
  });
}
async function fetchManageProducts(){
  const loading=document.getElementById('zq-prod-loading');
  const list=document.getElementById('zq-prod-list');
  loading.style.display='block';list.innerHTML='<p style="font-size:13px;color:var(--ink-4);padding:10px 0;">Loading all products…</p>';
  try{
    const status=document.getElementById('zq-prod-status-filter').value||'all';
    const params=new URLSearchParams();
    if(status!=='all')params.set('status',status);
    const r=await authFetch(API+'/manage-products?'+params);
    allManageProducts=await r.json();
    loading.style.display='none';
    renderManageProducts();
  }catch(e){loading.style.display='none';list.innerHTML='<p style="color:var(--danger);font-size:13px;">Failed to load products: '+e.message+'</p>';}
}
function renderManageProducts(){
  const list=document.getElementById('zq-prod-list');
  const search=(document.getElementById('zq-prod-search').value||'').toLowerCase().trim();
  const words=search?search.split(/\s+/).filter(Boolean):[];
  const products=words.length?allManageProducts.filter(p=>{
    const hay=(p.title+' '+(p.vendor||'')+' '+(p.product_type||'')+' '+((p.variants||[]).map(v=>v.sku||'').join(' '))+' '+(p.tags||'')).toLowerCase();
    return words.every(w=>hay.includes(w));
  }):allManageProducts;
  if(!products.length){list.innerHTML='<p class="zq-empty">No products found.</p>';return;}
  list.innerHTML=products.map(renderProductRow).join('');
}
function renderProductRow(p){
  const v=p.variants?.[0]||{};
  const statusColor={active:'var(--success)',draft:'var(--warning)',archived:'var(--ink-4)'};
  return `<div class="zq-card" style="margin-bottom:12px;padding:16px 20px;">
    <div style="display:flex;gap:16px;align-items:flex-start;">
      ${p.image?`<img src="${p.image.src}" style="width:56px;height:56px;object-fit:cover;border-radius:6px;flex-shrink:0;" />`:'<div style="width:56px;height:56px;background:var(--surface-3);border-radius:6px;flex-shrink:0;"></div>'}
      <div style="flex:1;min-width:0;">
        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:6px;">
          <span style="font-size:14px;font-weight:600;">${escHtml(p.title)}</span>
          <span style="font-size:11px;font-weight:600;padding:2px 8px;border-radius:3px;background:var(--surface-3);color:${statusColor[p.status]||'var(--ink-4)'};">${p.status}</span>
        </div>
        <div style="font-size:12px;color:var(--ink-4);display:flex;gap:12px;flex-wrap:wrap;">
          ${p.vendor?`<span>${escHtml(p.vendor)}</span>`:''}
          ${p.product_type?`<span>${escHtml(p.product_type)}</span>`:''}
          ${v.sku?`<span>SKU: ${escHtml(v.sku)}</span>`:''}
          <span>RRP: ${v.price?'$'+parseFloat(v.price).toFixed(2):'—'}</span>
          <span>${(p.variants||[]).length} variant${p.variants?.length!==1?'s':''}</span>
        </div>
      </div>
      <div style="display:flex;gap:8px;flex-shrink:0;">
        <button class="zq-btn zq-btn-sm" data-edit-product="${p.id}">Edit</button>
        <a href="https://36bb0d-2.myshopify.com/admin/products/${p.id}" target="_blank" class="zq-btn zq-btn-sm">Shopify ↗</a>
        <button class="zq-btn zq-btn-sm" style="color:var(--danger);border-color:var(--danger);" data-delete-product="${p.id}" data-product-title="${escHtml(p.title)}">Delete</button>
      </div>
    </div>
    <div id="zq-edit-prod-${p.id}" style="display:none;margin-top:16px;border-top:1px solid var(--rule);padding-top:16px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="zq-field"><label class="zq-label">Title</label><input class="zq-input" id="ep-title-${p.id}" value="${escHtml(p.title)}" /></div>
