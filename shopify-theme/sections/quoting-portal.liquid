  }catch(e){}
}
async function saveUsersToRailway(){
  try{await authFetch(API+'/users',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(USERS)});localStorage.setItem('zq_users',JSON.stringify(USERS));}
  catch(e){localStorage.setItem('zq_users',JSON.stringify(USERS));}
}
function saveUsers(){localStorage.setItem('zq_users',JSON.stringify(USERS));saveUsersToRailway();}
async function loadQuotesFromRailway(){
  setSyncStatus('Loading…');
  try{
    const res=await authFetch(API+'/quotes');const data=await res.json();
    if(Array.isArray(data)&&data.length>0){quotes=data;}
    else{const local=JSON.parse(localStorage.getItem('zq_quotes')||'[]');if(local.length>0){quotes=local;await saveQuotesToRailway();}}
    // Backfill: any quote without a salesperson that wasn't manually created gets Website
    let backfilled=false;
    quotes.forEach(q=>{if(!q.salesperson&&q.source!=='manual'){q.salesperson='Website';backfilled=true;}});
    if(backfilled)saveQuotes();
    if(quotes.length){let maxNum=100;quotes.forEach(q=>{const m=q.id.match(/^ZQ-0*(\d+)$/);if(m){const n=parseInt(m[1]);if(n>maxNum)maxNum=n;}});quoteCounter=maxNum;}
    setSyncStatus('');
  }catch(e){quotes=JSON.parse(localStorage.getItem('zq_quotes')||'[]');setSyncStatus('Offline mode');}
}
async function saveQuotesToRailway(){
  setSyncStatus('Saving…');
  try{await authFetch(API+'/quotes',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(quotes)});localStorage.setItem('zq_quotes',JSON.stringify(quotes));setSyncStatus('');}
  catch(e){localStorage.setItem('zq_quotes',JSON.stringify(quotes));setSyncStatus('Saved locally');}
}
function saveQuotes(){localStorage.setItem('zq_quotes',JSON.stringify(quotes));clearTimeout(saveTimer);saveTimer=setTimeout(saveQuotesToRailway,500);}
async function loadAllProducts(){
  if(productsLoaded)return;
  ['nq-products-loading','po-products-loading'].forEach(id=>{const el=document.getElementById(id);if(el)el.style.display='block';});
  try{const r=await authFetch(API+'/products');const d=await r.json();allProducts=d.products||[];productsLoaded=true;}catch(e){}
  ['nq-products-loading','po-products-loading'].forEach(id=>{const el=document.getElementById(id);if(el)el.style.display='none';});
}
async function loadCostsFromShopify(){
  if(costsLoaded)return;
  try{
    const r=await authFetch(API+'/variant-costs');const d=await r.json();
    if(Object.keys(d).length){
      // Merge only the AUD price from Shopify — preserve supplierCode and landedUSD
      Object.keys(d).forEach(vid=>{
        const existing=getCostData(vid);
        const incomingPrice=parseFloat(d[vid])||0;
        // Only update price if we don't already have one saved locally
        if(!existing.price&&incomingPrice){
          costs[String(vid)]={price:incomingPrice,supplierCode:existing.supplierCode,landedUSD:existing.landedUSD,supplierName:existing.supplierName};
        }
      });
      saveCosts();costsLoaded=true;
    }
  }catch(e){}
}
async function loadInventory(){
  if(inventoryLoaded)return;
  try{
    const r=await authFetch(API+'/inventory');const d=await r.json();
    const avail=d.available||d;
    Object.keys(avail).forEach(k=>{inventory[String(k)]=avail[k];});
    if(d.variantToInvItem){Object.keys(d.variantToInvItem).forEach(k=>{variantToInvItem[String(k)]=d.variantToInvItem[k];});}
    inventoryLoaded=true;if(newQuoteItems.length)zqRenderNewItems();zqRenderList();
  }catch(e){console.log('Inventory load failed');}
}
async function openForecastScreen(){
  zqShow('zq-forecast-screen');switchFcTab(activeFcTab);
  if(!productsLoaded)await loadAllProducts();
  if(!inventoryLoaded)await loadInventory();
  if(!posLoaded)await loadPOs();
  await loadLeadTimes();
  await loadStockSettings();
  // Pre-fetch sales for each distinct lead time in parallel
  const distinctWeeks=[...new Set(Object.values(leadTimes).map(w=>parseInt(w)||0).filter(w=>w>0))];
  await Promise.all(distinctWeeks.filter(w=>!salesCache[w]).map(w=>loadSalesData(w)));
  zqRenderForecast();renderPOList();
}
function switchFcTab(tab){
  activeFcTab=tab;
  document.querySelectorAll('.zq-fc-tab').forEach(t=>t.classList.toggle('active',t.dataset.fcTab===tab));
  document.getElementById('zq-fc-stock-panel').style.display=tab==='stock'?'block':'none';
  document.getElementById('zq-fc-po-panel').style.display=tab==='pos'?'block':'none';
  document.getElementById('zq-fc-costs-panel').style.display=tab==='costs'?'block':'none';
  document.getElementById('zq-fc-calc-panel').style.display=tab==='calc'?'block':'none';
  document.getElementById('zq-fc-stock-controls').style.display=tab==='stock'?'flex':'none';
  document.getElementById('zq-fc-po-controls').style.display=tab==='pos'?'flex':'none';
  document.getElementById('zq-fc-costs-controls').style.display=tab==='costs'?'flex':'none';
  document.getElementById('zq-fc-calc-controls').style.display=tab==='calc'?'flex':'none';
  if(tab==='costs'){
    if(!productsLoaded){loadAllProducts().then(()=>zqRenderCostList(''));}
    else{zqRenderCostList(document.getElementById('cost-search')?.value||'');}
  }
  if(tab==='calc'){
    if(!productsLoaded){loadAllProducts().then(()=>zqRenderCalcList(''));}
    else{zqRenderCalcList(document.getElementById('calc-search')?.value||'');}
  }
}
function zqRenderForecast(){
  const body=document.getElementById('zq-fc-body');
  const loading=document.getElementById('zq-fc-loading');
  const vendorFilter=(document.getElementById('zq-fc-vendor-filter')||{}).value||'all';
  const searchVal=((document.getElementById('zq-fc-search')||{}).value||'').toLowerCase().trim();
  if(!productsLoaded||!inventoryLoaded){loading.style.display='block';body.innerHTML='';return;}
  loading.style.display='none';
  const poTotals=buildPOTotals();
  const vendors=[...new Set(allProducts.flatMap(p=>(p.variants||[]).map(v=>getCostData(v.id).supplierName||p.vendor||'Unknown')).filter(Boolean))].sort();
  const sel=document.getElementById('zq-fc-vendor-filter');
  sel.innerHTML='<option value="all">All suppliers</option>';
  vendors.forEach(v=>{const o=document.createElement('option');o.value=v;o.textContent=v;if(v===vendorFilter)o.selected=true;sel.appendChild(o);});
  const grouped={};
  allProducts.forEach(p=>{
    (p.variants||[]).forEach(v=>{
      const vendor=getCostData(v.id).supplierName||p.vendor||'Unknown';
      if(vendorFilter!=='all'&&vendor!==vendorFilter)return;
      const name=p.productTitle+(v.title!=='Default Title'?' — '+v.title:'');
      const words=searchVal?searchVal.split(/\s+/).filter(Boolean):[];
      if(words.length&&!words.every(w=>name.toLowerCase().includes(w)||(v.sku||'').toLowerCase().includes(w)))return;
      if(!grouped[vendor])grouped[vendor]=[];
      grouped[vendor].push({variantId:v.id,name,sku:v.sku||'—',image:p.image});
    });
  });
  if(!Object.keys(grouped).length){body.innerHTML='<p class="zq-empty">No products found.</p>';return;}
  body.innerHTML='';
  Object.keys(grouped).sort().forEach(vendor=>{
    const rows=grouped[vendor];
    const totalHand=rows.reduce((s,r)=>s+(inventory[String(r.variantId)]||0),0);
    const totalPO=rows.reduce((s,r)=>s+(poTotals[String(r.variantId)]||0),0);
    const totalStock=totalHand+totalPO;
    const vk=vendor.replace(/[^a-z0-9]/gi,'_');
    const lt=leadTimes[vendor]||'';
    const vb=document.createElement('div');
    vb.className='zq-vendor-block';
    vb.innerHTML=
      '<div class="zq-vendor-header">'
        +'<span class="zq-vendor-name">'+vendor+'</span>'
        +'<span class="zq-vendor-meta">'
          +'<span>'+rows.length+' SKU'+(rows.length!==1?'s':'')+'</span>'
          +'<span style="color:var(--success);font-weight:600;">'+totalHand+' on hand</span>'
          +'<span style="color:var(--info);font-weight:600;">'+totalPO+' on PO</span>'
          +'<strong>'+totalStock+' total</strong>'
        +'</span>'
        +'<div style="display:flex;align-items:center;gap:12px;margin-left:auto;flex-wrap:wrap;">'
          +'<div style="display:flex;align-items:center;gap:6px;">'
            +'<span style="font-size:12px;color:var(--ink-4);white-space:nowrap;">Lead time (weeks)</span>'
            +'<input type="number" min="1" max="52" step="1" value="'+lt+'" placeholder="e.g. 8"'
              +' data-lead-time-vendor="'+vendor+'"'
              +' style="width:70px;padding:5px 8px;border:1px solid var(--rule);border-radius:4px;font-size:13px;font-family:\'Barlow\',sans-serif;background:var(--surface);text-align:center;" />'
          +'</div>'
          +'<div style="display:flex;align-items:center;gap:6px;">'
            +'<span style="font-size:12px;color:var(--ink-4);white-space:nowrap;">MOQ</span>'
            +'<input type="number" min="1" step="1" value="'+(stockSettings['vendor_moq_'+vk]||'')+'" placeholder="e.g. 10"'
              +' data-vendor-moq="'+vk+'"'
              +' style="width:70px;padding:5px 8px;border:1px solid var(--rule);border-radius:4px;font-size:13px;font-family:\'Barlow\',sans-serif;background:var(--surface);text-align:center;" />'
          +'</div>'
        +'</div>'
      +'</div>'
      +'<div style="overflow-x:auto;">'
        +'<table class="zq-table"><thead><tr>'
          +'<th style="width:52px;"></th>'
          +'<th>SKU</th>'
          +'<th>Product</th>'
          +'<th class="center">On hand</th>'
          +'<th class="center">Available</th>'
          +'<th class="center">On PO</th>'
          +'<th class="center">Total stock</th>'
          +'<th class="center">Threshold</th>'
          +'<th class="center" id="fc-sales-hdr-'+vk+'">Sales ('+(lt?lt+'wk':'—')+')</th>'
          +'<th class="center">Recommended</th>'
          +'<th class="center">New order</th>'
        +'</tr></thead>'
        +'<tbody id="fc-tbody-'+vk+'"></tbody></table>'
      +'</div>'
      +'<div class="zq-vendor-footer">'
        +'<button class="zq-btn zq-btn-sm" data-clear-vendor-po="'+vk+'">Clear</button>'
        +'<button class="zq-btn zq-btn-primary zq-btn-sm" data-create-vendor-po="'+vk+'" data-vendor-name="'+vendor+'">Create purchase order</button>'
      +'</div>';
    body.appendChild(vb);
    const tbody=document.getElementById('fc-tbody-'+vk);
    let visibleRows=0;
    rows.forEach(r=>{
      const onHand=inventory[String(r.variantId)]||0;
      const onPO=poTotals[String(r.variantId)]||0;
      const total=onHand+onPO;
      const lt=leadTimes[vendor]||'';
      const sold=lt?(salesCache[parseInt(lt)]||{})[String(r.variantId)]:undefined;
      const soldNum=parseInt(sold)||0;
      const recommended=lt?Math.max(0,soldNum-total):null;
      const ss=stockSettings[String(r.variantId)]||{};
      const threshold=parseInt(ss.threshold)||0;
      const vendorMoq=parseInt(stockSettings['vendor_moq_'+vk])||0;
      const isLow=threshold>0&&total<=threshold;
      // Apply filter
      if(fcNeedsOrderOnly&&(recommended===null||recommended===0)&&!isLow)return;
      visibleRows++;
      const hc=onHand<=0?'zq-fc-zero':onHand<=5?'zq-fc-low':'zq-fc-good';
      const tc=isLow?'zq-fc-low':(total<=0?'zq-fc-zero':total<=5?'zq-fc-low':'zq-fc-good');
      const soldDisplay=lt?(soldNum>0?'<span style="font-weight:600;color:var(--ink);">'+soldNum+'</span>':'<span class="zq-fc-zero">0</span>'):'<span class="zq-fc-zero">—</span>';
      const recDisplay=recommended===null?'<span class="zq-fc-zero">—</span>'
        :recommended===0?'<span class="zq-fc-good">✓</span>'
        :'<span style="font-weight:700;color:var(--danger);">'+recommended+'</span>';
      const iStyle='width:52px;padding:3px 6px;border:1px solid var(--rule);border-radius:4px;font-size:12px;text-align:center;font-family:\'Barlow\',sans-serif;background:var(--surface);';
      const tr=document.createElement('tr');
      if(isLow)tr.style.background='#fdf8ec';
      const safeName=r.name.replace(/"/g,'&quot;');
      const safeSku=(r.sku||'').replace(/"/g,'&quot;');
      const safeImage=(r.image||'').replace(/"/g,'&quot;');
      const prefilledQty=newOrderQtys[String(r.variantId)]||(isLow&&vendorMoq?vendorMoq:'')||'';
      tr.innerHTML=
        '<td>'+(r.image?'<img src="'+r.image+'" style="width:38px;height:38px;border-radius:4px;object-fit:cover;">':'')+'</td>'
        +'<td style="font-size:12px;color:var(--ink-4);">'+r.sku+'</td>'
        +'<td style="font-size:13px;font-weight:500;">'+(isLow?'<span style="color:var(--warning);">⚠</span> ':'')+r.name+'</td>'
        +'<td class="center"><span class="'+hc+'">'+onHand+'</span></td>'
        +'<td class="center"><span class="'+hc+'">'+onHand+'</span></td>'
        +'<td class="center"><span class="'+(onPO>0?'zq-fc-po':'zq-fc-zero')+'">'+(onPO>0?onPO:'—')+'</span></td>'
        +'<td class="center"><span class="'+tc+' zq-fc-total">'+total+'</span></td>'
        +'<td class="center"><input type="number" min="0" step="1" value="'+(threshold||'')+'" placeholder="—" data-ss-threshold="'+r.variantId+'" data-ss-name="'+safeName+'" data-ss-sku="'+safeSku+'" style="'+iStyle+'" /></td>'
        +'<td class="center" id="fc-sales-'+r.variantId+'">'+soldDisplay+'</td>'
        +'<td class="center">'+recDisplay+'</td>'
        +'<td class="center">'
          +'<input type="number" min="0" step="1" placeholder="—"'
          +' value="'+prefilledQty+'"'
          +' data-new-order-vid="'+r.variantId+'"'
          +' data-new-order-name="'+safeName+'"'
          +' data-new-order-sku="'+safeSku+'"'
          +' data-new-order-image="'+safeImage+'"'
          +' data-new-order-vendor="'+vk+'"'
          +' data-new-order-moq="'+vendorMoq+'"'
          +' class="zq-new-order-input" />'
          +(vendorMoq?'<div id="moq-err-'+r.variantId+'" style="display:none;font-size:11px;color:var(--danger);margin-top:2px;white-space:nowrap;">Min '+vendorMoq+'</div>':'')
        +'</td>';
      tbody.appendChild(tr);
    });
    // Hide entire vendor block if no rows match the filter
    if(fcNeedsOrderOnly&&visibleRows===0){
      vb.style.display='none';
    }
  });
}
function downloadPOPdf(poId){
  const po=purchaseOrders.find(p=>p.id===poId);
  if(!po)return;
  const {jsPDF}=window.jspdf;
  const doc=new jsPDF({orientation:'portrait',unit:'mm',format:'a4'});
  const W=210,H=297;
  const ml=16,mr=16,mt=16;
  const cw=W-ml-mr;
  // ── Helpers ──
  const hex=(h)=>{h=h.replace('#','');return[parseInt(h.slice(0,2),16),parseInt(h.slice(2,4),16),parseInt(h.slice(4,6),16)];};
  const ink=hex('0e0e0e'),ink3=hex('6b6b6b'),ink4=hex('9e9e9e'),rule=hex('e0e0e0'),surface2=hex('f7f7f7'),success=hex('1a6b3a'),successBg=hex('edf7f1'),info=hex('0a4a8a'),infoBg=hex('eef4fc'),warningBg=hex('fdf8ec'),warning=hex('8a5e00');
  const setFont=(size,style='normal',color=ink)=>{
    doc.setFontSize(size);
    doc.setFont('helvetica',style);
    doc.setTextColor(...color);
  };
  const drawLine=(x1,y1,x2,y2,color=rule,lw=0.2)=>{
    doc.setDrawColor(...color);doc.setLineWidth(lw);
    doc.line(x1,y1,x2,y2);
  };
  const rect=(x,y,w,h,fill,stroke)=>{
    if(fill)doc.setFillColor(...fill);
    if(stroke)doc.setDrawColor(...stroke);else doc.setDrawColor(...(fill||rule));
    doc.setLineWidth(0.2);
    if(fill&&stroke)doc.rect(x,y,w,h,'FD');
    else if(fill)doc.rect(x,y,w,h,'F');
    else doc.rect(x,y,w,h,'S');
  };
  const text=(str,x,y,opts={})=>doc.text(String(str),x,y,opts);
  let y=mt;
  // ── Header bar ──
  rect(0,0,W,22,ink);
  setFont(16,'bold',[255,255,255]);
  text('NUVIO',ml,13);
  setFont(8,'normal',[180,180,180]);
  text('PURCHASE ORDER',ml,18);
  setFont(9,'normal',[255,255,255]);
  text(po.id,W-mr,13,{align:'right'});
  setFont(7,'normal',[160,160,160]);
  text('nuvio.com.au',W-mr,18,{align:'right'});
  y=32;
  // ── PO meta grid ──
  const metaItems=[
    ['Supplier',po.supplier],
    ['Reference',po.ref||'—'],
    ['Expected arrival',po.arrival||'—'],
    ['Created',po.createdAt||'—'],
    ['Status',getPOStatus(po).toUpperCase()],
    ['Total SKUs',String((po.lineItems||[]).length)],
  ];
  const cols=3,colW=cw/cols,rowH=12;
  metaItems.forEach((item,i)=>{
    const col=i%cols,row=Math.floor(i/cols);
    const x=ml+col*colW,my=y+row*rowH;
    rect(x,my,colW-2,rowH,surface2);
    setFont(6,'normal',ink4);
    text(item[0].toUpperCase(),x+3,my+4);
    setFont(8,'bold',ink);
    text(item[1],x+3,my+9);
  });
  y+=Math.ceil(metaItems.length/cols)*rowH+6;
  // ── Notes ──
  if(po.notes){
    setFont(7,'normal',ink3);
    text('Notes: '+po.notes,ml,y);
    y+=6;
  }
  // ── Progress bar ──
  const lines=po.lineItems||[];
  const totalOrdered=lines.reduce((s,l)=>s+(l.qty||0),0);
  const totalReceived=lines.reduce((s,l)=>s+(l.received||0),0);
  const pct=totalOrdered>0?totalReceived/totalOrdered:0;
  rect(ml,y,cw,3,rule);
  if(pct>0)rect(ml,y,cw*pct,3,success);
  setFont(7,'normal',ink3);
  text('Received '+totalReceived+' of '+totalOrdered+' units ('+Math.round(pct*100)+'%)',ml,y+7);
  y+=12;
  // ── Divider ──
  drawLine(ml,y,W-mr,y,rule,0.3);
  y+=5;
  // ── Table header ──
  const cols_def=[
    {label:'#',w:7,align:'center'},
    {label:'Product',w:60,align:'left'},
    {label:'Supplier code',w:28,align:'left'},
    {label:'SKU',w:22,align:'left'},
    {label:'USD',w:22,align:'center'},
    {label:'Qty',w:15,align:'center'},
    {label:'USD total',w:24,align:'center'},
  ];
  // fill header bg
  rect(ml,y,cw,7,ink);
  let cx=ml;
  cols_def.forEach(col=>{
    setFont(6,'bold',[255,255,255]);
    const tx=col.align==='center'?cx+col.w/2:cx+2;
    text(col.label,tx,y+4.5,{align:col.align==='center'?'center':'left'});
    cx+=col.w;
  });
  y+=7;
  // ── Table rows ──
  lines.forEach((lineItem,idx)=>{
    const rowBg=idx%2===0?[255,255,255]:surface2;
    rect(ml,y,cw,8,rowBg);
    cx=ml;
    // #
    setFont(7,'normal',ink3);
    text(String(idx+1),cx+cols_def[0].w/2,y+5,{align:'center'});
    cx+=cols_def[0].w;
    // Product title only (strip variant after ' — ')
    setFont(7,'normal',ink);
    const maxNameW=cols_def[1].w-3;
    let nameStr=(lineItem.name||'').split(' — ')[0];
    while(doc.getTextWidth(nameStr)>maxNameW&&nameStr.length>0)nameStr=nameStr.slice(0,-1);
    if(nameStr!==(lineItem.name||'').split(' — ')[0])nameStr=nameStr.slice(0,-1)+'…';
    text(nameStr,cx+2,y+5);
    cx+=cols_def[1].w;
    // Supplier code
    const cd=getCostData(lineItem.variantId);
    setFont(7,'normal',ink3);
    let scStr=cd.supplierCode||'—';
    while(doc.getTextWidth(scStr)>cols_def[2].w-3&&scStr.length>0)scStr=scStr.slice(0,-1);
    text(scStr,cx+2,y+5);
    cx+=cols_def[2].w;
    // SKU
    setFont(7,'normal',ink3);
    let skuStr=lineItem.sku||'—';
    while(doc.getTextWidth(skuStr)>cols_def[3].w-3&&skuStr.length>0)skuStr=skuStr.slice(0,-1);
    text(skuStr,cx+2,y+5);
    cx+=cols_def[3].w;
    // USD unit
    const usdUnit=parseFloat(cd.landedUSD)||0;
    setFont(7,'normal',ink);
    text(usdUnit?'$'+usdUnit.toFixed(2):'—',cx+cols_def[4].w/2,y+5,{align:'center'});
    cx+=cols_def[4].w;
    // Qty
    setFont(8,'bold',ink);
    text(String(lineItem.qty||0),cx+cols_def[5].w/2,y+5,{align:'center'});
    cx+=cols_def[5].w;
    // USD total
    const usdTotal=usdUnit*(lineItem.qty||0);
    setFont(8,'bold',ink);
    text(usdTotal?'$'+usdTotal.toFixed(2):'—',cx+cols_def[6].w/2,y+5,{align:'center'});
    // bottom rule
    drawLine(ml,y+8,W-mr,y+8,rule,0.1);
    y+=8;
    // page break check
    if(y>H-30&&idx<lines.length-1){
      doc.addPage();
      y=mt;
      // repeat header
      rect(ml,y,cw,7,ink);
      cx=ml;
      cols_def.forEach(col=>{
        setFont(6,'bold',[255,255,255]);
        const tx=col.align==='center'?cx+col.w/2:cx+2;
        text(col.label,tx,y+4.5,{align:col.align==='center'?'center':'left'});
        cx+=col.w;
      });
      y+=7;
    }
  });
  y+=6;
  // ── Totals summary box ──
  const summaryH=20;
  if(y+summaryH>H-20){doc.addPage();y=mt;}
  const totalLandedUSD=lines.reduce((s,l)=>{const cd=getCostData(l.variantId);return s+(parseFloat(cd.landedUSD)||0)*(l.qty||0);},0);
  rect(ml,y,cw,summaryH,surface2,rule);
  setFont(7,'normal',ink3);
  text('Total qty ordered',ml+4,y+7);
  setFont(10,'bold',ink);
  text(String(totalOrdered),ml+4,y+15);
  setFont(7,'normal',ink3);
  text('Total USD',ml+cw/2,y+7);
  setFont(10,'bold',ink);
  text('$'+totalLandedUSD.toFixed(2),ml+cw/2,y+15);
  y+=summaryH+8;
  // ── Footer ──
  drawLine(ml,H-14,W-mr,H-14,rule,0.3);
  setFont(6,'normal',ink4);
  text('Generated by Nuvio Quoting Portal · '+new Date().toLocaleDateString('en-AU',{day:'numeric',month:'long',year:'numeric'}),ml,H-9);
  text(po.id,W-mr,H-9,{align:'right'});
  // ── Save ──
  const filename='PO-'+po.supplier.replace(/[^a-z0-9]/gi,'-')+'-'+po.id+'.pdf';
  doc.save(filename);
}
function renderPOList(){
  const list=document.getElementById('zq-po-list');
  if(!purchaseOrders.length){list.innerHTML='<p class="zq-empty">No purchase orders yet.</p>';return;}
  list.innerHTML='';
  [...purchaseOrders].reverse().forEach(po=>{
    const status=getPOStatus(po);
    const lines=po.lineItems||[];
    const totalOrdered=lines.reduce((s,l)=>s+(l.qty||0),0);
    const totalReceived=lines.reduce((s,l)=>s+(l.received||0),0);
    const pct=totalOrdered>0?Math.round(totalReceived/totalOrdered*100):0;
    const el=document.createElement('div');el.className='zq-po-row';
    el.innerHTML=
      '<div class="zq-po-header" data-po-toggle="'+po.id+'">'
        +'<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;min-width:0;">'
          +'<span style="font-family:\'Barlow Condensed\',sans-serif;font-size:16px;font-weight:500;letter-spacing:0.04em;">'+po.supplier+'</span>'
          +(po.ref?'<span style="font-size:12px;color:var(--ink-4);">'+po.ref+'</span>':'')
          +'<span class="zq-badge zq-badge-'+status+'">'+status+'</span>'
          +'<span style="font-size:12px;color:var(--ink-4);">'+lines.length+' SKU'+(lines.length!==1?'s':'')+' · '+totalReceived+'/'+totalOrdered+' received</span>'
        +'</div>'
        +'<div style="display:flex;align-items:center;gap:12px;flex-shrink:0;">'
