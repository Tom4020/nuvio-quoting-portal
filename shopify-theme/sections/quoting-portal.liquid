let csvRows=[];
const CSV_HEADERS=['title','vendor','product_type','tags','status','sku','price','compare_at_price','barcode','weight','description'];
function downloadCsvTemplate(){
  const rows=[CSV_HEADERS.join(','),['Sample Product','Nuvio','Bathware','vanity,stone','active','SKU-001','499.00','','9312345678901','25.0','Product description here'].join(',')];
  const blob=new Blob([rows.join('\n')],{type:'text/csv'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='nuvio_product_import_template.csv';a.click();
}
function parseCsv(text){
  const lines=text.split(/\r?\n/).filter(Boolean);
  if(!lines.length)return[];
  const headers=lines[0].split(',').map(h=>h.trim().toLowerCase().replace(/"/g,''));
  return lines.slice(1).map(line=>{
    // Handle quoted fields
    const vals=[];let cur='';let inQ=false;
    for(let i=0;i<line.length;i++){
      if(line[i]==='"'){inQ=!inQ;}
      else if(line[i]===','&&!inQ){vals.push(cur.trim());cur='';}
      else cur+=line[i];
    }
    vals.push(cur.trim());
    const row={};headers.forEach((h,i)=>{row[h]=vals[i]||'';});
    return row;
  }).filter(r=>r.title);
}
async function importCsvProducts(){
  const btn=document.getElementById('zq-csv-import-btn');
  const progress=document.getElementById('zq-csv-progress');
  const errEl=document.getElementById('zq-csv-err');
  errEl.style.display='none';
  if(!csvRows.length)return;
  btn.disabled=true;progress.style.display='block';
  let done=0,failed=0;
  for(const row of csvRows){
    progress.textContent=`Importing… ${done+failed+1} / ${csvRows.length}`;
    try{
      const r=await authFetch(API+'/manage-products',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
        title:row.title,
        body_html:row.description||'',
        vendor:row.vendor||'',
        product_type:row.product_type||'',
        tags:row.tags||'',
        status:row.status||'active',
        variants:[{price:row.price||'0',compare_at_price:row.compare_at_price||null,sku:row.sku||'',barcode:row.barcode||'',weight:parseFloat(row.weight)||0,weight_unit:'kg',inventory_management:'shopify'}]
      })});
      const d=await r.json();
      if(d.id)done++;else failed++;
    }catch(e){failed++;}
    await new Promise(r=>setTimeout(r,300)); // rate limit
  }
  progress.textContent=`Done! ${done} created, ${failed} failed.`;
  btn.disabled=false;
  if(done>0)loadManageProducts();
}
