function zqOpenQuoteForm(title,items,customer,discount,notes,editId,expiry,projectName){
  editingQuoteId=editId||null;newQuoteItems=items?items.map(i=>({...i})):[];
  document.getElementById('zq-form-title').textContent=title;
  document.getElementById('nq-submit-btn').textContent=editId?'Save changes →':'Create & send quote →';
  document.getElementById('nq-cust-search').value='';document.getElementById('nq-cust-results').style.display='none';
  document.getElementById('nq-name').value=customer?customer.name:'';document.getElementById('nq-email').value=customer?customer.email:'';
  document.getElementById('nq-phone').value=customer?customer.phone:'';document.getElementById('nq-company').value=customer?customer.company:'';
  document.getElementById('nq-address').value=customer?customer.address:'';document.getElementById('nq-project').value=projectName||'';document.getElementById('nq-notes').value=notes||'';
  document.getElementById('nq-search').value='';document.getElementById('nq-search-results').style.display='none';
  document.getElementById('nq-expiry').value=expiry?dateToInput(expiry):dateToInput(expiryDate());
  const existingQ=editId?quotes.find(x=>x.id===editId):null;
  document.getElementById('nq-free-shipping').checked=existingQ?(existingQ.freeShipping||false):false;
  const ad=document.getElementById('nq-disc-admin');const sd=document.getElementById('nq-disc-staff');
  if(isAdmin()){ad.style.display='flex';sd.style.display='none';document.getElementById('nq-discount').value=discount||0;}
  else{ad.style.display='none';sd.style.display='block';sd.querySelectorAll('.zq-disc-btn').forEach(b=>b.classList.toggle('active',parseInt(b.dataset.disc)===(discount||0)));newQuoteItems.forEach(i=>i.discount=discount||0);}
  zqRenderNewItems();zqUpdateNewMargin();zqShow('zq-quote-form-screen');
  checkAccountCustomer(customer?customer.email:'');
  setTimeout(()=>{const input=document.getElementById('nq-address');if(input)zqAttachAutocomplete(input);},300);
}
function zqSubmitQuote(){
  const name=document.getElementById('nq-name').value.trim();const email=document.getElementById('nq-email').value.trim();
  if(!name||!email){alert('Please enter customer name and email.');return;}
  if(!newQuoteItems.length){alert('Please add at least one product.');return;}
  const expiry=inputToDate(document.getElementById('nq-expiry').value)||expiryDate();
  const freeShipping=document.getElementById('nq-free-shipping').checked;
  const projectName=document.getElementById('nq-project').value.trim();
  const customer={name,email,phone:document.getElementById('nq-phone').value.trim(),company:document.getElementById('nq-company').value.trim(),address:document.getElementById('nq-address').value.trim()};
  if(editingQuoteId){const q=quotes.find(x=>x.id===editingQuoteId);q.customer=customer;q.projectName=projectName;q.items=newQuoteItems.map(i=>({...i}));q.notes=document.getElementById('nq-notes').value.trim();q.expiry=expiry;q.freeShipping=freeShipping;saveQuotes();zqShowDash();}
  else{const q={id:nextId(),status:'pending',source:'manual',salesperson:currentUser?currentUser.name:'Tom',date:today(),expiry,freeShipping,customer,projectName,items:newQuoteItems.map(i=>({...i})),notes:document.getElementById('nq-notes').value.trim()};quotes.push(q);saveQuotes();zqOpenSend(q.id);}
}
