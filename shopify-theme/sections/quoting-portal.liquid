async function zqConfirmSend(){
  const q=quotes.find(x=>x.id===activeQuoteId);const btn=document.getElementById('zq-confirm-send-btn');
  if(btn){btn.textContent='Sending…';btn.disabled=true;}
  const addr=parseAddress(q.customer.address);const firstName=q.customer.name.split(' ')[0];const lastName=q.customer.name.split(' ').slice(1).join(' ')||'.';
  const customMessage=document.getElementById('zq-email-msg')?.value||'';
  const ccRaw=document.getElementById('zq-email-cc')?.value||'';
  const ccEmails=ccRaw.split(',').map(e=>e.trim()).filter(e=>e.includes('@'));
  const projectNote=q.projectName?' · Project: '+q.projectName:'';
  const body={draft_order:{email:q.customer.email,line_items:q.items.map(i=>({variant_id:i.variantId,quantity:i.qty,discount_percentage:i.discount||0,requires_shipping:true})),customer:{email:q.customer.email,first_name:firstName,last_name:lastName},shipping_address:{first_name:firstName,last_name:lastName,company:q.customer.company||'',address1:addr.address1,city:addr.city,province:addr.province,zip:addr.zip,phone:q.customer.phone||'',country:'Australia'},note:'Trade quote '+q.id+projectNote+' · Expires '+(q.expiry||'')+' · Nuvio Quoting Portal',tags:'trade-quote,'+q.id},draft_order_message:customMessage,cc_emails:ccEmails,project_name:q.projectName||''};
  if(q.freeShipping){body.draft_order.shipping_line={title:'Free Shipping',price:'0.00',code:'FREE'};}
  try{
    const res=await authFetch(API+'/create-draft-order',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    const data=await res.json();
    if(data.draft_order){q.status='sent';q.shopifyDraftId=data.draft_order.id;q.checkoutUrl=data.draft_order.invoice_url;saveQuotes();document.getElementById('zq-succ-msg').textContent='Quote '+q.id+' sent to '+q.customer.name;document.getElementById('zq-succ-sub').textContent='Draft order created · Invoice emailed to '+q.customer.email;zqShow('zq-success-screen');}
    else{if(btn){btn.textContent='Confirm and send →';btn.disabled=false;}alert('Shopify error: '+JSON.stringify(data.errors||data));}
  }catch(err){if(btn){btn.textContent='Confirm and send →';btn.disabled=false;}alert('Connection error: '+err.message);}
}
async function zqChargeToAccount(){
  const name=document.getElementById('nq-name').value.trim();const email=document.getElementById('nq-email').value.trim();
  if(!name||!email){alert('Please enter customer name and email.');return;}
  if(!newQuoteItems.length){alert('Please add at least one product.');return;}
  const btn=document.getElementById('nq-account-btn');
  btn.textContent='Placing order…';btn.disabled=true;
  const address=document.getElementById('nq-address').value.trim();
  const notes=document.getElementById('nq-notes').value.trim();
  const company=document.getElementById('nq-company').value.trim();
  const phone=document.getElementById('nq-phone').value.trim();
  const freeShipping=document.getElementById('nq-free-shipping').checked;
  const addr=parseAddress(address);
  const firstName=name.split(' ')[0];const lastName=name.split(' ').slice(1).join(' ')||'.';
  const globalDisc=isAdmin()?parseFloat(document.getElementById('nq-discount').value)||0:0;
  const items=newQuoteItems.map(i=>{
    const disc=i.discount||globalDisc||0;
    return{variant_id:i.variantId,quantity:i.qty,discount_percentage:disc,requires_shipping:true};
  });
  const totals=calcTotals(newQuoteItems);
  const dueDate=new Date(Date.now()+30*24*60*60*1000).toLocaleDateString('en-AU');
  const body={
    draft_order:{
      email,line_items:items,
      customer:{email,first_name:firstName,last_name:lastName},
      shipping_address:{first_name:firstName,last_name:lastName,company:company,address1:addr.address1,city:addr.city,province:addr.province,zip:addr.zip,phone:phone,country:'Australia',country_code:'AU'},
      note:'30-DAY ACCOUNT · Due: '+dueDate+' · Quote Portal order'+(notes?' · '+notes:''),
      tags:'trade-client,account-order,quote-portal',
      payment_terms:{payment_terms_name:'Net 30',payment_schedule:{issued_at:new Date().toISOString()}},
    },
    draft_order_message:'',auto_complete:true,skip_invoice:true,
    account_order_total:totals.discounted
  };
  if(freeShipping){body.draft_order.shipping_line={title:'Free Shipping',price:'0.00',code:'FREE'};}
  try{
    const res=await authFetch(API+'/create-draft-order',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    const data=await res.json();
    if(data.error){btn.textContent='Charge to 30-day account';btn.disabled=false;alert(data.error);return;}
    if(data.draft_order){
      document.getElementById('zq-succ-msg').textContent='Order charged to 30-day account';
      document.getElementById('zq-succ-sub').textContent='Order placed for '+name+' · Payment due within 30 days';
      zqShow('zq-success-screen');
    }else{btn.textContent='Charge to 30-day account';btn.disabled=false;alert('Shopify error: '+JSON.stringify(data.errors||data));}
  }catch(err){btn.textContent='Charge to 30-day account';btn.disabled=false;alert('Connection error: '+err.message);}
}
