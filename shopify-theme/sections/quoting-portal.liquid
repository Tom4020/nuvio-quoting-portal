function zqAttachAutocomplete(inputEl){
  if(!inputEl||!window.google||inputEl.dataset.acAttached)return;
  inputEl.dataset.acAttached='1';
  const ac=new google.maps.places.Autocomplete(inputEl,{types:['address'],componentRestrictions:{country:'au'},fields:['formatted_address','address_components']});
  ac.addListener('place_changed',()=>{
    const p=ac.getPlace();
    if(p.formatted_address)inputEl.value=p.formatted_address;
    if(p.address_components){
      const get=(type)=>(p.address_components.find(c=>c.types.includes(type))||{}).long_name||'';
      const getShort=(type)=>(p.address_components.find(c=>c.types.includes(type))||{}).short_name||'';
      const streetNum=get('street_number');
      const route=get('route');
      const subpremise=get('subpremise');
      inputEl.dataset.address1=(subpremise?subpremise+'/':'')+((streetNum?streetNum+' ':'')+route).trim();
      inputEl.dataset.city=get('locality')||get('administrative_area_level_2')||'';
      inputEl.dataset.province=getShort('administrative_area_level_1')||'';
      inputEl.dataset.zip=get('postal_code')||'';
    }
  });
}
