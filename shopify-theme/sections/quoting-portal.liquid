  if(!confirm('Delete this image?'))return;
  try{
    await authFetch(API+'/manage-products/'+productId+'/images/'+imageId,{method:'DELETE'});
    const tile=document.getElementById('img-tile-'+imageId);
    if(tile)tile.remove();
  }catch(e){alert('Delete failed: '+e.message);}
}
