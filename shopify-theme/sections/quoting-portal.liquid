    const isBelowMoq=moq>0&&qty>0&&qty<moq;
    t.style.borderColor=isBelowMoq?'var(--danger)':'';
    t.style.background=isBelowMoq?'#fff5f5':'';
    if(errEl)errEl.style.display=isBelowMoq?'block':'none';
  }
  if(t.dataset.verifyPo&&t.files&&t.files[0]){
    verifySupplierInvoice(t.dataset.verifyPo,t.files[0]);
    t.value=''; // reset so same file can be re-uploaded
  }
});
