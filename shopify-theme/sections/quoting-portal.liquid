async function sendProformaEmail(draftId,email,customerName,btn){
  const recipient=email||prompt('Enter the customer email address:');
  if(!recipient) return;
  if(!confirm('Send proforma invoice to '+recipient+'?')) return;
  const origText=btn.innerHTML;
  btn.innerHTML='Sending…';btn.disabled=true;btn.style.opacity='0.6';
  try{
    const r=await authFetch(API+'/send-proforma/'+draftId,{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({email:recipient})
    });
    const data=await r.json();
    if(data.ok){
      btn.innerHTML='✓ Sent';btn.style.background='#22863a';btn.style.color='#fff';
      setTimeout(()=>{btn.innerHTML=origText;btn.disabled=false;btn.style.opacity='1';btn.style.background='';btn.style.color='';},3000);
    }else{
      alert('Failed to send: '+(data.error||'Unknown error'));
      btn.innerHTML=origText;btn.disabled=false;btn.style.opacity='1';
    }
  }catch(e){
    alert('Failed to send proforma. Please try again.');
    btn.innerHTML=origText;btn.disabled=false;btn.style.opacity='1';
  }
}

