function getMonthKey(s){if(!s)return'';const p=s.split(' ');if(p.length!==3)return'';return p[2]+'-'+String(MONTHS.indexOf(p[1])+1).padStart(2,'0');}
function prevMonthKey(k){if(!k)return'';const[y,m]=k.split('-').map(Number);const d=new Date(y,m-2,1);return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');}
function buildMonthOptions(){
  const keys=new Set();const now=new Date();
  for(let i=0;i<12;i++){const d=new Date(now.getFullYear(),now.getMonth()-i,1);keys.add(d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0'));}
  quotes.filter(q=>q.status==='converted').forEach(q=>{const k=getMonthKey(q.date);if(k)keys.add(k);});
  return[...keys].sort().reverse();
}
function calcCommission(name,monthKey){
  const user=USERS.find(u=>u.name===name);const rate=user?(parseFloat(user.commission)||0):0;
  const converted=quotes.filter(q=>q.status==='converted'&&(q.salesperson||'Tom')===name&&getMonthKey(q.date)===monthKey);
  const totalMargin=converted.reduce((s,q)=>s+calcTotals(q.items).margin,0);
  return{commission:totalMargin*rate/100,totalMargin,rate,count:converted.length};
}
function calcQuoteValue(name,monthKey){
  const mq=quotes.filter(q=>(q.salesperson||'Tom')===name&&getMonthKey(q.date)===monthKey);
  return{total:mq.reduce((s,q)=>s+calcTotals(q.items).discounted,0),count:mq.length};
}
function renderCommissionBox(){
  const sel=document.getElementById('zq-comm-month-sel');const months=buildMonthOptions();
  if(sel.options.length===0){months.forEach(k=>{const[y,m]=k.split('-');const o=document.createElement('option');o.value=k;o.textContent=MONTHS[parseInt(m)-1]+' '+y;sel.appendChild(o);});}
  const sm=sel.value||months[0]||'';const pm=prevMonthKey(sm);
  if(isAdmin()){
    document.getElementById('zq-comm-title').textContent='Commission summary';
    document.getElementById('zq-admin-comm-wrap').style.display='flex';
    const names=[...new Set(USERS.map(u=>u.name))];let total=0;
    const grid=document.getElementById('zq-admin-comm-grid');grid.innerHTML='';
    names.forEach(name=>{
      const{commission,totalMargin,rate,count}=calcCommission(name,sm);total+=commission;
      const{commission:prevComm}=calcCommission(name,pm);
      const{total:qTotal,count:qCount}=calcQuoteValue(name,sm);
      const card=document.createElement('div');card.className='zq-admin-comm-card';
      card.innerHTML='<div class="zq-admin-comm-name">'+name+'</div><div class="zq-admin-comm-val">'+fmt(commission)+'</div><div style="margin-top:4px;">'+changeLabel(commission,prevComm)+'</div><div class="zq-admin-comm-sub" style="margin-top:6px;">'+rate+'% of '+fmt(totalMargin)+' · '+count+' converted</div><div class="zq-admin-comm-quote-val">'+fmt(qTotal)+' quoted</div><div class="zq-admin-comm-quote-sub">'+qCount+' quote'+(qCount!==1?'s':'')+' this month</div>';
      grid.appendChild(card);
    });
    document.getElementById('zq-comm-value').textContent=fmt(total);
    document.getElementById('zq-comm-sub').textContent='Total commission payable';
    document.getElementById('zq-comm-breakdown').innerHTML=changeLabel(total,0);
  }else{
    document.getElementById('zq-admin-comm-wrap').style.display='none';
    const{commission,totalMargin,rate,count}=calcCommission(currentUser.name,sm);
    const{commission:prevComm}=calcCommission(currentUser.name,pm);
    document.getElementById('zq-comm-title').textContent='My monthly commission';
    document.getElementById('zq-comm-value').textContent=fmt(commission);
    document.getElementById('zq-comm-sub').textContent=rate>0?rate+'% of '+fmt(totalMargin)+' margin':'No commission rate set';
    document.getElementById('zq-comm-breakdown').innerHTML=count+' converted quote'+(count!==1?'s':'')+' · '+changeLabel(commission,prevComm);
  }
}
function zqRenderList(){
  const list=document.getElementById('zq-list');
