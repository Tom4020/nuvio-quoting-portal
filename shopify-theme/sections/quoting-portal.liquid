    ]).then(()=>{
      btn.textContent='✓ Saved';
      setTimeout(()=>{btn.textContent='↑ Shopify';btn.disabled=false;},2000);
    }).catch(()=>{
      btn.textContent='Failed';
      setTimeout(()=>{btn.textContent='↑ Shopify';btn.disabled=false;},2000);
    });
    return;
  }
  if(btn.id==='zq-save-calc-btn'){saveCalcData();btn.textContent='Saved ✓';setTimeout(()=>{btn.textContent='Save calculations';},2000);return;}
  if(btn.id==='zq-save-costs-btn'){saveCosts();btn.textContent='Saved ✓';setTimeout(()=>{btn.textContent='Save all costs';},2000);return;}
