function dateToInput(str){if(!str)return'';const p=str.split(' ');if(p.length!==3)return'';return p[2]+'-'+String(MONTHS.indexOf(p[1])+1).padStart(2,'0')+'-'+p[0].padStart(2,'0');}
function inputToDate(val){if(!val)return'';const[y,m,d]=val.split('-');return parseInt(d)+' '+MONTHS[parseInt(m)-1]+' '+y;}
function daysUntilExpiry(s){if(!s)return null;const p=s.split(' ');return Math.ceil((new Date(parseInt(p[2]),MONTHS.indexOf(p[1]),parseInt(p[0]))-new Date())/86400000);}
function getCost(vid){return getCostData(vid).price;}
function calcTotals(items){
  const subtotal=items.reduce((s,i)=>s+i.rrp*i.qty,0);
  const cost=items.reduce((s,i)=>s+getCost(i.variantId)*i.qty,0);
  const discounted=items.reduce((s,i)=>s+(i.rrp*(1-(i.discount||0)/100))*i.qty,0);
  const margin=discounted-cost;const marginPct=discounted>0?(margin/discounted*100):0;const saving=subtotal-discounted;
  return{subtotal,cost,discounted,margin,marginPct,saving};
}
function parseAddress(addr){
  if(!addr)return{address1:'',city:'',province:'',zip:''};
  const sm={'New South Wales':'NSW','Victoria':'VIC','Queensland':'QLD','South Australia':'SA','Western Australia':'WA','Tasmania':'TAS','Australian Capital Territory':'ACT','Northern Territory':'NT'};
  let c=addr.replace(/,?\s*Australia\s*$/i,'').trim();
  Object.entries(sm).forEach(([f,a])=>{c=c.replace(new RegExp(f,'gi'),a);});
  const parts=c.split(',').map(s=>s.trim()).filter(Boolean);

  /* Google Places format: "Unit 8 67-71 Vicars St, Mitchell NSW 2911" */
  if(parts.length>=2){
    const address1=parts[0];
    const rest=parts.slice(1).join(' ').trim();
    const m=rest.match(/^(.*?)\s+(NSW|VIC|QLD|SA|WA|TAS|ACT|NT)\s+(\d{4})$/i);
    if(m)return{address1,city:m[1].trim(),province:m[2].toUpperCase(),zip:m[3]};
    /* Try: "Suburb, STATE POSTCODE" as separate parts */
    const m2=rest.match(/^(.*?)\s+(NSW|VIC|QLD|SA|WA|TAS|ACT|NT)\s*(\d{4})?$/i);
    if(m2)return{address1,city:m2[1].trim(),province:m2[2].toUpperCase(),zip:m2[3]||''};
    /* Fallback: just split remaining words */
    const w=rest.split(' ').filter(Boolean);
    const zip=/^\d{4}$/.test(w[w.length-1])?w.pop():'';
    const province=/^(NSW|VIC|QLD|SA|WA|TAS|ACT|NT)$/i.test(w[w.length-1])?w.pop().toUpperCase():'';
    return{address1,city:w.join(' '),province,zip};
  }

  /* No commas — try to find STATE POSTCODE at end of string */
  const full=c.match(/^(.+?)\s+(.*?)\s+(NSW|VIC|QLD|SA|WA|TAS|ACT|NT)\s+(\d{4})$/i);
  if(full){
    /* Heuristic: first line is street, second is suburb */
    return{address1:full[1].trim(),city:full[2].trim(),province:full[3].toUpperCase(),zip:full[4]};
  }

  /* Last resort — everything as address1 */
  return{address1:c,city:'',province:'',zip:''};
}
function marginHTML(t){
