document.addEventListener('change',function(e){
  if(e.target.dataset.uploadImgs){
    const productId=e.target.dataset.uploadImgs;
    const files=Array.from(e.target.files);
    if(!files.length)return;
    uploadProductImages(productId,files);
    e.target.value='';
  }
});
async function uploadProductImages(productId,files){
  const grid=document.getElementById('ep-imgs-'+productId);
  for(const file of files){
    const reader=new FileReader();
    reader.onload=async ev=>{
      const base64=ev.target.result.split(',')[1];
      try{
        const r=await authFetch(API+'/manage-products/'+productId+'/images',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({attachment:base64,filename:file.name})});
        const img=await r.json();
        if(img.id){
          // Insert before the upload tile
          const uploadTile=grid.querySelector('label.zq-img-upload-tile');
          const tile=document.createElement('div');
          tile.className='zq-img-tile';tile.id='img-tile-'+img.id;
          tile.innerHTML=`<img src="${img.src}" /><button class="zq-img-tile-del" data-del-img="${img.id}" data-prod-id="${productId}" title="Delete">✕</button>`;
          grid.insertBefore(tile,uploadTile);
        }
      }catch(e){alert('Image upload failed: '+e.message);}
    };
    reader.readAsDataURL(file);
  }
}
