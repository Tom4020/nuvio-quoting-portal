function saveCalcData(){
  localStorage.setItem('zq_calc',JSON.stringify(calcData));
  // Write calculated Total cost AUD back to costs[vid].price as source of truth
  allProducts.forEach(p=>{
    (p.variants||[]).forEach(v=>{
      const vid=String(v.id);
      const rrp=parseFloat(v.price)||0;
      const totalCostAUD=calcTotalCostAUD(vid,rrp);
      if(totalCostAUD>0){
        const existing=getCostData(vid);
        costs[vid]={price:parseFloat(totalCostAUD.toFixed(2)),supplierCode:existing.supplierCode,landedUSD:existing.landedUSD,supplierName:existing.supplierName};
      }
    });
  });
  saveCosts(); // saves costs + __calc to Railway in one call
}
function calcTotalCostAUD(vid,rrp){
  const cd=getCostData(vid);
  const cr=getCalcRow(vid);
  const rate=parseFloat(calcData.audUsd)||0;
  const supplierUSD=parseFloat(cd.landedUSD)||0;
  const totalUSD=supplierUSD+cr.packaging+cr.freight;
  const landedAUD=rate>0?(totalUSD/rate)*1.15:0; // +15% import tax
  const platformFees=rrp>0?(rrp*0.022+0.04):0;
  return landedAUD+cr.localPackaging+platformFees;
}
function zqRenderCalcList(search){
  const list=document.getElementById('zq-calc-list');
  const s=(search||'').toLowerCase();
  const matches=[];
  const words=s?s.split(/\s+/).filter(Boolean):[];
  allProducts.forEach(p=>{
    (p.variants||[]).forEach(v=>{
      const name=p.productTitle+(v.title!=='Default Title'?' — '+v.title:'');
      if(!words.length||words.every(w=>name.toLowerCase().includes(w)||(v.sku||'').toLowerCase().includes(w)))
        matches.push({id:v.id,name:p.productTitle,sku:v.sku||'',rrp:parseFloat(v.price)||0});
    });
  });
  if(!matches.length){list.innerHTML='<p class="zq-empty" style="padding:20px;">No products found.</p>';return;}
  const rate=parseFloat(calcData.audUsd)||0;
  const rateInp=document.getElementById('calc-audusd');
  if(rateInp&&!rateInp.value)rateInp.value=rate||'';
  const rateDisplay=document.getElementById('calc-audusd-display');
  if(rateDisplay)rateDisplay.textContent=rate?rate.toFixed(4):'—';
  const iStyle='padding:5px 8px;border:1px solid var(--rule);border-radius:4px;font-size:13px;font-family:\'Barlow\',sans-serif;background:var(--surface);color:var(--ink);width:80px;text-align:right;';
  const th=(label,align,sub)=>'<th style="font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-4);padding:8px 10px;border-bottom:1px solid var(--rule);background:var(--surface-2);white-space:nowrap;text-align:'+(align||'left')+';">'+label+(sub?'<div style="font-size:9px;font-weight:400;color:var(--ink-4);letter-spacing:0;text-transform:none;margin-top:2px;">'+sub+'</div>':'')+'</th>';
  const inp=(field,vid,val)=>'<div style="display:flex;align-items:center;gap:4px;justify-content:center;"><span style="font-size:12px;color:var(--ink-4);">$</span><input type="number" min="0" step="0.01" value="'+(val||'')+'" placeholder="0.00" data-calc-'+field+'="'+vid+'" style="'+iStyle+'" /></div>';
  let html='<div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;"><thead><tr>'
    +th('Product')
    +th('SKU')
    +th('Supplier USD','right')
    +th('Packaging USD','center')
    +th('Freight USD','center')
    +th('Landed AUD','right','USD ÷ rate + 15% tax')
    +th('Local pkg AUD','center')
    +th('Platform fees AUD','right','2.2% RRP + $0.04')
    +th('Total cost AUD','right','→ updates cost prices')
    +th('RRP','right')
    +th('Margin','right')
    +'</tr></thead><tbody>';
  matches.forEach((p,i)=>{
    const cd=getCostData(p.id);
    const cr=getCalcRow(p.id);
    const rrp=p.rrp;
    const supplierUSD=parseFloat(cd.landedUSD)||0;
    const totalUSD=supplierUSD+cr.packaging+cr.freight;
    const landedAUD=rate>0?(totalUSD/rate)*1.15:0; // +15% import tax
    const platformFees=rrp>0?(rrp*0.022+0.04):0;
    const totalCostAUD=landedAUD+cr.localPackaging+platformFees;
    const margin=(rrp>0&&totalCostAUD>0)?((rrp-totalCostAUD)/rrp*100):null;
    const marginColor=margin===null?'var(--ink-4)':margin>=50?'var(--success)':margin>=30?'var(--warning)':'var(--danger)';
    const rowBg=i%2===0?'var(--surface)':'var(--surface-2)';
    const cell=(content,align,extra)=>'<td style="padding:9px 10px;border-bottom:1px solid var(--rule-light);vertical-align:middle;font-size:13px;text-align:'+(align||'left')+';'+(extra||'')+'">'+(content)+'</td>';
    const dash='<span style="color:var(--ink-4);">—</span>';
    html+='<tr style="background:'+rowBg+';">'
      +cell('<span style="font-weight:500;">'+p.name+'</span>')
      +cell('<span style="font-size:12px;color:var(--ink-4);">'+p.sku+'</span>')
      +cell(supplierUSD?'$'+supplierUSD.toFixed(2):dash,'right','color:var(--ink-3);')
      +cell(inp('packaging',p.id,cr.packaging||''))
      +cell(inp('freight',p.id,cr.freight||''))
      +'<td style="padding:9px 10px;border-bottom:1px solid var(--rule-light);vertical-align:middle;font-size:13px;text-align:right;font-weight:600;" id="calc-landed-aud-'+p.id+'" data-rrp="'+rrp+'" data-rate="'+rate+'">'+(landedAUD>0?'$'+landedAUD.toFixed(2):dash)+'</td>'
      +cell(inp('local-packaging',p.id,cr.localPackaging||''))
      +cell(platformFees>0?'<span style="color:var(--ink-3);">$'+platformFees.toFixed(2)+'</span>':dash,'right','')
      +'<td style="padding:9px 10px;border-bottom:1px solid var(--rule-light);vertical-align:middle;font-size:13px;text-align:right;font-weight:700;color:var(--success);" id="calc-total-aud-'+p.id+'" data-rrp="'+rrp+'">'+(totalCostAUD>0?'$'+totalCostAUD.toFixed(2):dash)+'</td>'
      +cell(rrp?'$'+rrp.toFixed(2):'—','right','color:var(--ink-3);')
      +'<td style="padding:9px 10px;border-bottom:1px solid var(--rule-light);vertical-align:middle;font-size:13px;text-align:right;font-weight:700;" id="calc-margin-'+p.id+'">'+(margin!==null?'<span style="color:'+marginColor+';">'+margin.toFixed(1)+'%</span>':dash)+'</td>'
      +'</tr>';
  });
  html+='</tbody></table></div>';
  list.innerHTML=html;
}
function getCalcRow(vid){
  const r=calcData[String(vid)];
  return{
    packaging:parseFloat(r&&r.packaging)||0,
    freight:parseFloat(r&&r.freight)||0,
    localPackaging:parseFloat(r&&r.localPackaging)||0
  };
}
function zqUpdateCalcRow(vid){
  const cd=getCostData(vid);
  const cr=getCalcRow(vid);
  const landedEl=document.getElementById('calc-landed-aud-'+vid);
  if(!landedEl)return;
  const rate=parseFloat(landedEl.dataset.rate)||parseFloat(calcData.audUsd)||0;
  const rrp=parseFloat(landedEl.dataset.rrp)||0;
  const supplierUSD=parseFloat(cd.landedUSD)||0;
  const totalUSD=supplierUSD+cr.packaging+cr.freight;
  const landedAUD=rate>0?(totalUSD/rate)*1.15:0; // +15% import tax
  const platformFees=rrp>0?(rrp*0.022+0.04):0;
  const totalCostAUD=landedAUD+cr.localPackaging+platformFees;
  const margin=(rrp>0&&totalCostAUD>0)?((rrp-totalCostAUD)/rrp*100):null;
  const marginColor=margin===null?'var(--ink-4)':margin>=50?'var(--success)':margin>=30?'var(--warning)':'var(--danger)';
  const dash='<span style="color:var(--ink-4);">—</span>';
  landedEl.innerHTML=landedAUD>0?'$'+landedAUD.toFixed(2):dash;
  const totalEl=document.getElementById('calc-total-aud-'+vid);
  if(totalEl)totalEl.innerHTML=totalCostAUD>0?'$'+totalCostAUD.toFixed(2):dash;
  const marginEl=document.getElementById('calc-margin-'+vid);
  if(marginEl)marginEl.innerHTML=margin!==null?'<span style="color:'+marginColor+';">'+margin.toFixed(1)+'%</span>':dash;
}
