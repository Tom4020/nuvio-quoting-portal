let allPortalOrders=[];
let ordersSearchTerm='';
let ordersFilterStatus='all';

async function openOrdersScreen(){
  zqShow('zq-orders-screen');
  if(!allPortalOrders.length) await loadPortalOrders();
  else renderPortalOrdersList();
}

async function loadPortalOrders(){
  const loading=document.getElementById('zq-orders-loading');
  const list=document.getElementById('zq-orders-list');
  loading.style.display='block'; list.innerHTML='';
  try{
    const r=await authFetch(API+'/admin/orders?limit=250&status=any');
    allPortalOrders=await r.json();
  }catch(e){allPortalOrders=[];}
  loading.style.display='none';
  renderPortalOrdersList();
}

function getFilteredPortalOrders(){
  let orders=allPortalOrders;
  if(ordersFilterStatus!=='all'){
    orders=orders.filter(o=>o.status===ordersFilterStatus);
  }
  if(ordersSearchTerm){
    const q=ordersSearchTerm.toLowerCase();
    orders=orders.filter(o=>
      (o.name||'').toLowerCase().includes(q)||
      (o.customer||'').toLowerCase().includes(q)||
      (o.email||'').toLowerCase().includes(q)||
      (o.company||'').toLowerCase().includes(q)
    );
  }
  return orders;
}

let orderDetailCache={};

function renderPortalOrdersList(){
  const list=document.getElementById('zq-orders-list');
  const orders=getFilteredPortalOrders();
  if(!orders.length){
    list.innerHTML='<div style="text-align:center;padding:40px;color:var(--ink-4);font-size:13px;">No orders found.</div>';
    return;
  }
  const fmtD=v=>'$'+parseFloat(v||0).toFixed(2);
  const dateAU=d=>new Date(d).toLocaleDateString('en-AU',{day:'numeric',month:'short',year:'numeric'});
  const statusBadge=s=>{
    const colors={paid:'#22863a',pending:'#d29922',authorized:'#0366d6',refunded:'#6a737d',voided:'#cb2431',partially_paid:'#d29922',partially_refunded:'#6a737d'};
    const c=colors[s]||'#6a737d';
    return '<span style="display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;color:'+c+';background:'+c+'14;">'+(s||'unknown')+'</span>';
  };
  const fulfillBadge=f=>{
    const c=f==='fulfilled'?'#22863a':f==='partial'?'#d29922':'#6a737d';
    return '<span style="display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;color:'+c+';background:'+c+'14;">'+f+'</span>';
  };

  let html='<table style="width:100%;border-collapse:collapse;font-size:13px;">';
  html+='<thead><tr style="background:var(--surface-2);border-bottom:1px solid var(--rule);">';
  html+='<th style="text-align:left;padding:10px 12px;font-size:11px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;color:var(--ink-4);">Order</th>';
  html+='<th style="text-align:left;padding:10px 12px;font-size:11px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;color:var(--ink-4);">Customer</th>';
  html+='<th style="text-align:left;padding:10px 12px;font-size:11px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;color:var(--ink-4);">Date</th>';
  html+='<th style="text-align:left;padding:10px 12px;font-size:11px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;color:var(--ink-4);">Payment</th>';
  html+='<th style="text-align:left;padding:10px 12px;font-size:11px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;color:var(--ink-4);">Fulfillment</th>';
  html+='<th style="text-align:right;padding:10px 12px;font-size:11px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;color:var(--ink-4);">Total</th>';
  html+='<th style="text-align:center;padding:10px 12px;font-size:11px;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;color:var(--ink-4);">Invoice</th>';
  html+='</tr></thead><tbody>';

  orders.forEach((o,i)=>{
    const bg=i%2===0?'':'background:var(--surface-2);';
    html+='<tr style="border-bottom:1px solid var(--rule);'+bg+'">';
    html+='<td style="padding:10px 12px;font-weight:600;"><a href="#" data-order-detail="'+o.id+'" style="color:var(--accent);text-decoration:none;cursor:pointer;">'+(o.name||'')+'</a></td>';
    html+='<td style="padding:10px 12px;">'+(o.customer||'Guest')+(o.company?'<br><span style="font-size:11px;color:var(--ink-4);">'+o.company+'</span>':'')+'</td>';
    html+='<td style="padding:10px 12px;">'+dateAU(o.createdAt)+'</td>';
    html+='<td style="padding:10px 12px;">'+statusBadge(o.status)+'</td>';
    html+='<td style="padding:10px 12px;">'+fulfillBadge(o.fulfillment)+'</td>';
    html+='<td style="padding:10px 12px;text-align:right;font-weight:600;">'+fmtD(o.total)+'</td>';
    const payBtn=(o.status!=='paid'&&o.status!=='refunded'&&o.status!=='voided')?' <a href="https://nuvio-quoting-portal-production.up.railway.app/pay/'+o.id+'" target="_blank" style="display:inline-block;padding:5px 12px;background:#22863a;color:#fff;border-radius:var(--radius);font-size:11px;font-weight:600;text-decoration:none;margin-left:4px;">Pay</a>':'';
    const sendBtn=' <button data-send-invoice="'+o.id+'" data-send-email="'+(o.email||'')+'" data-send-name="'+(o.name||'')+'" style="display:inline-block;padding:5px 12px;background:var(--accent);color:#fff;border:none;border-radius:var(--radius);font-size:11px;font-weight:600;cursor:pointer;margin-left:4px;">✉ Send</button>';
    const copyBtn=' <button data-copy-invoice="https://nuvio-quoting-portal-production.up.railway.app/invoice/'+o.id+'" style="display:inline-block;padding:5px 12px;background:var(--surface-2);color:var(--ink);border:1px solid var(--rule);border-radius:var(--radius);font-size:11px;font-weight:600;cursor:pointer;margin-left:4px;">🔗 Link</button>';
    html+='<td style="padding:10px 12px;text-align:center;"><a href="https://nuvio-quoting-portal-production.up.railway.app/invoice/'+o.id+'" target="_blank" style="display:inline-block;padding:5px 12px;background:var(--ink);color:#fff;border-radius:var(--radius);font-size:11px;font-weight:600;text-decoration:none;">↓ Invoice</a>'+sendBtn+copyBtn+payBtn+'</td>';
    html+='</tr>';
    // Detail dropdown row (hidden by default)
    html+='<tr id="zq-order-detail-'+o.id+'" style="display:none;"><td colspan="7" style="padding:0;border-bottom:1px solid var(--rule);"><div id="zq-order-detail-content-'+o.id+'" style="padding:16px 20px;background:var(--surface-2);"></div></td></tr>';
