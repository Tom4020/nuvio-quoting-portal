  }
  if(btn.dataset.savePoRecv){
    const poId=btn.dataset.savePoRecv;const po=purchaseOrders.find(p=>p.id===poId);if(!po)return;
    const lines=po.lineItems.map((line,idx)=>{const inp=document.querySelector('input[data-po-id="'+poId+'"][data-line-idx="'+idx+'"]');const newReceived=inp?Math.min(parseInt(inp.value)||0,line.qty):(line.received||0);return{variantId:line.variantId,inventoryItemId:variantToInvItem[String(line.variantId)]||null,prevReceived:line.received||0,newReceived};});
    const hasChanges=lines.some(l=>l.newReceived!==l.prevReceived);
