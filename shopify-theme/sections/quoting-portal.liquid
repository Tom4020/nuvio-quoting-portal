  if(btn.dataset.uploadToShopify!==undefined){
    const vid=btn.dataset.uploadToShopify;
    const codeInp=document.querySelector('input[data-supplier-code-id="'+vid+'"]');
    const costInp=document.querySelector('input[data-cost-id="'+vid+'"]');
    const code=codeInp?codeInp.value.trim():'';
