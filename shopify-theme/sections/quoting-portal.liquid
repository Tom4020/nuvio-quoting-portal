{% comment %} Nuvio Quoting Portal — sections/quoting-portal.liquid {% endcomment %}
{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,500;0,600;1,300&family=Barlow+Condensed:wght@300;400;500;600&display=swap');
  :root {
    --ink: #1e4e1c;
    --ink-2: #3a3a3a;
    --ink-3: #6b6b6b;
    --ink-4: #9e9e9e;
    --rule: #e0e0e0;
    --rule-light: #f0f0f0;
    --surface: #ffffff;
    --surface-2: #f7f7f7;
    --surface-3: #f0f0f0;
    --accent: #1e4e1c;
    --accent-hover: #2d6b2a;
    --danger: #c0392b;
    --danger-bg: #fdf3f2;
    --success: #1a6b3a;
    --success-bg: #edf7f1;
    --warning: #8a5e00;
    --warning-bg: #fdf8ec;
    --info: #0a4a8a;
    --info-bg: #eef4fc;
    --radius: 6px;
    --radius-lg: 10px;
    --shadow: 0 1px 3px rgba(0,0,0,0.07), 0 4px 16px rgba(0,0,0,0.04);
    --shadow-lg: 0 2px 8px rgba(0,0,0,0.08), 0 12px 40px rgba(0,0,0,0.08);
    --transition: 0.18s ease;
  }
  .zq * { box-sizing: border-box; }
  .zq {
    font-family: 'Barlow', sans-serif;
    font-weight: 400;
    font-size: 14px;
    color: var(--ink);
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 24px 80px;
    line-height: 1.5;
  }
  /* ── TYPOGRAPHY ── */
  .zq-wordmark {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 300;
    font-size: 28px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0;
  }
  .zq-page-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 500;
    font-size: 22px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0;
  }
  .zq-section-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 18px;
  }
  /* ── LAYOUT ── */
  .zq-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 36px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--rule);
    flex-wrap: wrap;
    gap: 12px;
  }
  .zq-topbar-left { display: flex; align-items: center; gap: 16px; }
  .zq-topbar-right { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .zq-screen-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--rule);
    flex-wrap: wrap;
  }
  .zq-screen-header-actions { margin-left: auto; display: flex; gap: 8px; flex-wrap: wrap; }
  .zq-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .zq-stack { display: flex; flex-direction: column; gap: 16px; }
  /* ── CARDS ── */
  .zq-card {
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    padding: 28px;
  }
  .zq-card-sm { padding: 20px; }
  /* ── FORM ELEMENTS ── */
  .zq-field { margin-bottom: 14px; }
  .zq-field:last-child { margin-bottom: 0; }
  .zq-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 6px;
  }
  .zq-input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    font-size: 14px;
    font-family: 'Barlow', sans-serif;
    font-weight: 400;
    background: var(--surface);
    color: var(--ink);
    transition: border-color var(--transition), box-shadow var(--transition);
    appearance: none;
  }
  .zq-input:focus {
    outline: none;
    border-color: var(--ink);
    box-shadow: 0 0 0 3px rgba(14,14,14,0.06);
  }
  .zq-input::placeholder { color: var(--ink-4); }
  textarea.zq-input { min-height: 72px; resize: vertical; }
  select.zq-input { cursor: pointer; }
  /* ── BUTTONS ── */
  .zq-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 16px;
    border-radius: var(--radius);
    font-size: 13px;
    font-family: 'Barlow', sans-serif;
    font-weight: 500;
    letter-spacing: 0.02em;
    cursor: pointer;
    border: 1px solid var(--rule);
    background: var(--surface);
    color: var(--ink-2);
    transition: background var(--transition), border-color var(--transition), color var(--transition), transform var(--transition);
    white-space: nowrap;
  }
  .zq-btn:hover { background: var(--surface-2); border-color: #c8c8c8; }
  .zq-btn:active { transform: scale(0.98); }
  .zq-btn-primary {
    background: var(--ink);
    color: #fff;
    border-color: var(--ink);
  }
  .zq-btn-primary:hover { background: var(--accent-hover); border-color: var(--accent-hover); }
  .zq-btn-danger { color: var(--danger); border-color: #e8c8c6; }
  .zq-btn-danger:hover { background: var(--danger-bg); border-color: #dba8a4; }
  .zq-btn-ghost { border-color: transparent; background: transparent; }
  .zq-btn-ghost:hover { background: var(--surface-2); border-color: var(--rule); }
  .zq-btn-sm { padding: 7px 13px; font-size: 12px; }
  .zq-btn-xs { padding: 4px 9px; font-size: 11px; }
  .zq-btn-full { width: 100%; justify-content: center; padding: 12px 16px; font-size: 14px; }
  .zq-btn:disabled { opacity: 0.45; cursor: not-allowed; transform: none; }
  /* ── BADGES ── */
  .zq-badge {
    display: inline-flex;
    align-items: center;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 3px;
  }
  .zq-badge-pending  { background: var(--warning-bg); color: var(--warning); }
  .zq-badge-sent     { background: var(--info-bg); color: var(--info); }
  .zq-badge-converted{ background: var(--success-bg); color: var(--success); }
  .zq-badge-declined { background: var(--surface-3); color: var(--ink-4); }
  .zq-badge-expiring { background: #fef3e2; color: #a05a00; }
  .zq-badge-expired  { background: var(--danger-bg); color: var(--danger); }
  .zq-badge-ordered  { background: var(--info-bg); color: var(--info); }
  .zq-badge-partial  { background: var(--warning-bg); color: var(--warning); }
  .zq-badge-complete { background: var(--success-bg); color: var(--success); }
  .zq-badge-admin    { background: var(--ink); color: #fff; }
  .zq-badge-staff    { background: var(--surface-3); color: var(--ink-2); }
  .zq-badge-margin   { background: var(--info-bg); color: var(--info); font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 3px; letter-spacing: 0.06em; }
  .zq-badge-ship     { background: var(--success-bg); color: var(--success); font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 3px; letter-spacing: 0.06em; }
  .zq-stock-badge    { display: inline-flex; font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 3px; margin-left: 6px; }
  .zq-stock-in  { background: var(--success-bg); color: var(--success); }
  .zq-stock-low { background: var(--warning-bg); color: var(--warning); }
  .zq-stock-out { background: var(--danger-bg); color: var(--danger); }
  /* ── LOGIN ── */
  .zq-login-wrap {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .zq-login-box {
    width: 100%;
    max-width: 360px;
  }
  .zq-login-header { text-align: center; margin-bottom: 32px; }
  .zq-login-header p { color: var(--ink-3); font-size: 13px; margin-top: 6px; }
  /* ── STATS ── */
  .zq-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 28px;
  }
  .zq-stat {
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    padding: 18px 20px;
  }
  .zq-stat-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-4);
    margin-bottom: 6px;
  }
  .zq-stat-value {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 32px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1;
  }
  /* ── COMMISSION BOX ── */
  .zq-comm-box {
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    padding: 24px 28px;
    margin-bottom: 24px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  .zq-comm-primary {}
  .zq-comm-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-4);
    margin-bottom: 4px;
  }
  .zq-comm-value {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 40px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1;
    margin-bottom: 6px;
  }
  .zq-comm-sub { font-size: 12px; color: var(--ink-3); }
  .zq-comm-breakdown { font-size: 12px; color: var(--ink-4); margin-top: 4px; }
  .zq-comm-month select {
    padding: 7px 12px;
    border-radius: var(--radius);
    border: 1px solid var(--rule);
    background: var(--surface);
    color: var(--ink);
    font-size: 13px;
    font-family: 'Barlow', sans-serif;
    cursor: pointer;
  }
  .zq-admin-comm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
    flex: 1;
  }
  .zq-admin-comm-card {
    background: var(--surface-2);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 16px;
  }
  .zq-admin-comm-name { font-size: 12px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 4px; }
  .zq-admin-comm-val { font-family: 'Barlow Condensed', sans-serif; font-size: 26px; font-weight: 500; color: var(--ink); }
  .zq-admin-comm-sub { font-size: 11px; color: var(--ink-4); margin-top: 4px; }
  .zq-admin-comm-quote-val { font-size: 12px; font-weight: 600; color: var(--info); margin-top: 8px; }
  .zq-admin-comm-quote-sub { font-size: 11px; color: var(--ink-4); margin-top: 2px; }
  .zq-change-up   { color: var(--success); font-size: 11px; font-weight: 600; }
  .zq-change-down { color: var(--danger); font-size: 11px; font-weight: 600; }
  .zq-change-flat { color: var(--ink-4); font-size: 11px; }
  /* ── TABS ── */
  .zq-tabs {
    display: flex;
    gap: 2px;
    margin-bottom: 14px;
    flex-wrap: wrap;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 0;
  }
  .zq-tab {
    padding: 8px 16px;
    border-radius: var(--radius) var(--radius) 0 0;
    border: 1px solid transparent;
    border-bottom: none;
    background: transparent;
    font-size: 13px;
    font-family: 'Barlow', sans-serif;
    font-weight: 400;
    cursor: pointer;
    color: var(--ink-3);
    position: relative;
    bottom: -1px;
    transition: all var(--transition);
  }
  .zq-tab:hover { color: var(--ink); background: var(--surface-2); }
  .zq-tab.active {
    background: var(--surface);
    color: var(--ink);
    font-weight: 500;
    border-color: var(--rule);
    border-bottom-color: var(--surface);
  }
  /* ── FILTERS ── */
  .zq-filters {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
    flex-wrap: wrap;
    align-items: center;
  }
  .zq-search-bar {
    flex: 1;
    min-width: 220px;
    padding: 9px 14px;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    font-size: 13px;
    font-family: 'Barlow', sans-serif;
    background: var(--surface);
    color: var(--ink);
    transition: border-color var(--transition), box-shadow var(--transition);
  }
  .zq-search-bar:focus { outline: none; border-color: var(--ink); box-shadow: 0 0 0 3px rgba(14,14,14,0.06); }
  .zq-search-bar::placeholder { color: var(--ink-4); }
  .zq-filter-select {
    padding: 9px 12px;
    border-radius: var(--radius);
    border: 1px solid var(--rule);
    background: var(--surface);
    font-size: 13px;
    font-family: 'Barlow', sans-serif;
    cursor: pointer;
    color: var(--ink-2);
  }
  /* ── QUOTE ROWS ── */
  .zq-quote-row {
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    margin-bottom: 8px;
    overflow: hidden;
    transition: box-shadow var(--transition);
  }
  .zq-quote-row:hover { box-shadow: var(--shadow); }
  .zq-quote-row.expiring { border-color: #f0c060; }
  .zq-quote-row.expired { border-color: #e8a09a; }
  .zq-quote-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 20px;
    cursor: pointer;
    user-select: none;
  }
  .zq-quote-header:hover { background: var(--surface-2); }
  .zq-quote-meta { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; min-width: 0; }
  .zq-quote-id { font-family: 'Barlow Condensed', sans-serif; font-size: 15px; font-weight: 600; letter-spacing: 0.04em; }
  .zq-quote-customer { font-size: 13px; color: var(--ink-2); }
  .zq-quote-right { display: flex; align-items: center; gap: 16px; flex-shrink: 0; }
  .zq-quote-date { font-size: 12px; color: var(--ink-4); }
  .zq-quote-total { font-family: 'Barlow Condensed', sans-serif; font-size: 18px; font-weight: 500; }
  .zq-quote-body { display: none; border-top: 1px solid var(--rule-light); padding: 24px; }
  .zq-quote-body.open { display: block; }
  /* ── INFO GRID ── */
  .zq-info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }
  .zq-info-item {}
  .zq-info-label { font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-4); margin-bottom: 3px; }
  .zq-info-value { font-size: 13px; font-weight: 500; color: var(--ink); }
  .zq-info-value a { color: var(--info); text-decoration: none; }
  .zq-info-value a:hover { text-decoration: underline; }
  /* ── TABLES ── */
  .zq-table-wrap { overflow-x: auto; margin-bottom: 20px; }
  .zq-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .zq-table th {
    text-align: left;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-4);
    padding: 8px 10px;
    border-bottom: 1px solid var(--rule);
    white-space: nowrap;
    background: var(--surface-2);
  }
  .zq-table th.center { text-align: center; }
  .zq-table td {
    padding: 10px 10px;
    border-bottom: 1px solid var(--rule-light);
    color: var(--ink);
    vertical-align: middle;
  }
  .zq-table td.center { text-align: center; }
  .zq-table tr:last-child td { border-bottom: none; }
  .zq-table tr:hover td { background: var(--surface-2); }
  /* ── QUOTE FORM ITEMS ── */
  .zq-search-wrap { position: relative; }
  .zq-search-results {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    max-height: 300px;
    overflow-y: auto;
    z-index: 300;
  }
  .zq-search-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    cursor: pointer;
    font-size: 13px;
    border-bottom: 1px solid var(--rule-light);
    transition: background var(--transition);
  }
  .zq-search-item:last-child { border-bottom: none; }
  .zq-search-item:hover { background: var(--surface-2); }
  .zq-search-thumb { width: 36px; height: 36px; border-radius: 4px; object-fit: cover; flex-shrink: 0; background: var(--surface-3); }
  .zq-cust-result { padding: 10px 12px; cursor: pointer; border-bottom: 1px solid var(--rule-light); transition: background var(--transition); }
  .zq-cust-result:last-child { border-bottom: none; }
  .zq-cust-result:hover { background: var(--surface-2); }
  .zq-added-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--rule-light);
  }
  .zq-added-item:last-child { border-bottom: none; }
  .zq-added-thumb { width: 44px; height: 44px; border-radius: 4px; object-fit: cover; flex-shrink: 0; background: var(--surface-3); }
  /* ── DISCOUNT ── */
  .zq-disc-wrap {
    background: var(--surface-2);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 14px;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .zq-disc-label { font-size: 12px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-3); white-space: nowrap; }
  .zq-disc-btns { display: flex; gap: 4px; }
  .zq-disc-btn {
    padding: 6px 12px;
    border-radius: 4px;
    border: 1px solid var(--rule);
    background: var(--surface);
    font-size: 12px;
    font-family: 'Barlow', sans-serif;
    cursor: pointer;
    color: var(--ink-2);
    transition: all var(--transition);
  }
  .zq-disc-btn:hover { background: var(--surface-3); }
  .zq-disc-btn.active { background: var(--ink); color: #fff; border-color: var(--ink); }
  /* ── MARGIN BOX ── */
  .zq-margin-box {
    background: var(--surface-2);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 14px 16px;
  }
  .zq-margin-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: var(--ink-3);
    padding: 3px 0;
  }
  .zq-margin-row.total { font-weight: 600; color: var(--ink); border-top: 1px solid var(--rule); margin-top: 8px; padding-top: 10px; }
  .zq-margin-row.profit { color: var(--success); font-weight: 600; }
  .zq-margin-row.saving { color: var(--success); }
  .zq-margin-row.commission { color: var(--warning); font-weight: 600; }
  /* ── CHECKBOX ── */
  .zq-checkbox-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--surface-2);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    margin-bottom: 14px;
  }
  .zq-checkbox-row input[type="checkbox"] { width: 15px; height: 15px; cursor: pointer; flex-shrink: 0; accent-color: var(--ink); }
  .zq-checkbox-row label { font-size: 13px; font-weight: 500; cursor: pointer; }
  .zq-checkbox-row span { font-size: 12px; color: var(--ink-4); }
  /* ── SEND SCREEN ── */
  .zq-send-summary {
    background: var(--surface-2);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 20px;
  }
  .zq-send-notice {
    background: var(--info-bg);
    border: 1px solid #c0d8f4;
    border-radius: var(--radius);
    padding: 14px 16px;
    font-size: 13px;
    color: var(--info);
    margin-bottom: 20px;
    line-height: 1.7;
  }
  /* ── SUCCESS ── */
  .zq-success-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
  }
  .zq-success-box {
    text-align: center;
    max-width: 420px;
    padding: 48px 32px;
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
  }
  .zq-success-icon {
    font-size: 40px;
    margin-bottom: 16px;
    display: block;
  }
  /* ── QUOTE ACTIONS ── */
  .zq-quote-actions { display: flex; gap: 8px; margin-top: 20px; flex-wrap: wrap; padding-top: 16px; border-top: 1px solid var(--rule-light); }
  /* ── EXPIRY ── */
  .zq-expiry-wrap { display: flex; align-items: center; gap: 6px; }
  .zq-expiry-input { padding: 4px 8px; border: 1px solid var(--rule); border-radius: 4px; font-size: 12px; font-family: 'Barlow', sans-serif; background: var(--surface); color: var(--ink); }
  /* ── CONTROLS ── */
  .zq-two-col-controls { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  /* ── FORECAST / FC TABS ── */
  .zq-fc-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 24px;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    overflow: hidden;
    width: fit-content;
  }
  .zq-fc-tab {
    padding: 9px 22px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    background: var(--surface);
    border: none;
    color: var(--ink-3);
    font-family: 'Barlow', sans-serif;
    border-right: 1px solid var(--rule);
    letter-spacing: 0.02em;
    transition: all var(--transition);
  }
  .zq-fc-tab:last-child { border-right: none; }
  .zq-fc-tab.active { background: var(--ink); color: #fff; }
  .zq-fc-tab:hover:not(.active) { background: var(--surface-2); color: var(--ink); }
  /* ── VENDOR BLOCKS ── */
  /* Rich text editor */
  .zq-rte-wrap { border:1px solid var(--rule);border-radius:6px;overflow:hidden;background:var(--surface); }
  .zq-rte-toolbar { display:flex;gap:2px;padding:6px 8px;background:var(--surface-2);border-bottom:1px solid var(--rule);flex-wrap:wrap; }
  .zq-rte-btn { padding:4px 8px;border:none;background:none;cursor:pointer;border-radius:4px;font-size:13px;color:var(--ink-3);font-family:'Barlow',sans-serif; }
  .zq-rte-btn:hover { background:var(--surface-3);color:var(--ink); }
  .zq-rte-btn.active { background:var(--ink);color:var(--surface); }
  .zq-rte-editor { min-height:120px;padding:12px;outline:none;font-size:14px;font-family:'Barlow',sans-serif;color:var(--ink);line-height:1.6; }
  .zq-rte-editor:empty:before { content:attr(data-placeholder);color:var(--ink-4); }
  /* Product image grid */
  .zq-img-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:12px;margin-top:12px; }
  .zq-img-tile { position:relative;aspect-ratio:1;border-radius:6px;overflow:hidden;border:1px solid var(--rule); }
  .zq-img-tile img { width:100%;height:100%;object-fit:cover; }
  .zq-img-tile-del { position:absolute;top:4px;right:4px;background:rgba(0,0,0,0.6);color:#fff;border:none;border-radius:50%;width:22px;height:22px;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1; }
  .zq-img-upload-tile { aspect-ratio:1;border:2px dashed var(--rule);border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;color:var(--ink-4);font-size:12px;gap:6px;transition:border-color 0.15s; }
  .zq-img-upload-tile:hover { border-color:var(--ink-3);color:var(--ink-3); }
  .zq-vendor-block {
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    margin-bottom: 20px;
    overflow: hidden;
  }
  .zq-vendor-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 20px;
    background: var(--surface-2);
    border-bottom: 1px solid var(--rule);
    flex-wrap: wrap;
    gap: 8px;
  }
  .zq-vendor-name { font-family: 'Barlow Condensed', sans-serif; font-size: 16px; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink); }
  .zq-vendor-meta { font-size: 12px; color: var(--ink-4); display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .zq-vendor-footer {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 8px;
    padding: 14px 20px;
    border-top: 1px solid var(--rule-light);
    background: var(--surface-2);
  }
  /* FC stock colors */
  .zq-fc-zero  { color: #ccc; }
  .zq-fc-low   { color: var(--warning); font-weight: 600; }
  .zq-fc-good  { color: var(--success); font-weight: 600; }
  .zq-fc-po    { color: var(--info); font-weight: 600; }
  .zq-fc-total { font-weight: 700; }
  .zq-new-order-input {
    width: 64px;
    padding: 4px 6px;
    border: 1px solid var(--rule);
    border-radius: 4px;
    font-size: 13px;
    text-align: center;
    font-family: 'Barlow', sans-serif;
    background: var(--surface);
    color: var(--ink);
    transition: border-color var(--transition), box-shadow var(--transition);
  }
  .zq-new-order-input:focus { outline: none; border-color: var(--ink); box-shadow: 0 0 0 3px rgba(14,14,14,0.06); }
  .zq-new-order-input::placeholder { color: var(--ink-4); }
  /* ── PO ROWS ── */
  .zq-po-row {
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    margin-bottom: 10px;
    overflow: hidden;
  }
  .zq-po-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 20px;
    cursor: pointer;
  }
  .zq-po-header:hover { background: var(--surface-2); }
  .zq-po-body { display: none; border-top: 1px solid var(--rule); padding: 24px; }
  .zq-po-body.open { display: block; }
  .zq-po-line {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--rule-light);
    font-size: 13px;
  }
  .zq-po-line:last-child { border-bottom: none; }
  .zq-po-thumb { width: 36px; height: 36px; border-radius: 4px; object-fit: cover; flex-shrink: 0; background: var(--surface-3); }
  .zq-po-recv-input { width: 72px; padding: 4px 8px; border: 1px solid var(--rule); border-radius: 4px; font-size: 13px; text-align: center; font-family: 'Barlow', sans-serif; background: var(--surface); }
  .zq-progress { height: 3px; background: var(--rule); border-radius: 2px; margin-top: 6px; overflow: hidden; }
  .zq-progress-bar { height: 100%; background: var(--success); border-radius: 2px; transition: width 0.4s ease; }
  /* ── COST ITEMS ── */
  .zq-cost-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--rule-light);
    font-size: 13px;
  }
  .zq-cost-item:last-child { border-bottom: none; }
  .zq-cost-thumb { width: 36px; height: 36px; border-radius: 4px; object-fit: cover; flex-shrink: 0; background: var(--surface-3); }
  /* ── USERS ── */
  .zq-user-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid var(--rule-light);
    font-size: 13px;
    gap: 12px;
    flex-wrap: wrap;
  }
  .zq-user-row:last-child { border-bottom: none; }
  /* ── MISC ── */
  .zq-err { color: var(--danger); font-size: 12px; margin-top: 8px; }
  .zq-search-item.selected { background: var(--surface-3); }
  .zq-search-item.selected .zq-search-check { opacity: 1; color: var(--success); }
  .zq-search-check { width:16px;height:16px;flex-shrink:0;font-size:14px;opacity:0.25;transition:opacity 0.15s; }
  .zq-search-confirm { display:flex;align-items:center;justify-content:space-between;padding:10px 12px;border-top:2px solid var(--rule);background:var(--surface-2);position:sticky;bottom:0; }
  .zq-empty { font-size: 13px; color: var(--ink-4); padding: 20px 0; }
  .zq-syncing { font-size: 12px; color: var(--ink-4); }
  .zq-qty-input { width: 72px; padding: 4px 8px; border: 1px solid var(--rule); border-radius: 4px; font-size: 13px; text-align: center; font-family: 'Barlow', sans-serif; background: var(--surface); color: var(--ink); }
  .pac-container { z-index: 10000 !important; font-family: 'Barlow', sans-serif !important; }
  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .zq-fade-up { animation: fadeUp 0.22s ease forwards; }
  /* ── RESPONSIVE ── */
  @media (max-width: 800px) {
    .zq { padding: 24px 16px 60px; }
    .zq-stats-grid { grid-template-columns: repeat(2, 1fr); }
    .zq-two-col { grid-template-columns: 1fr; }
    .zq-two-col-controls { grid-template-columns: 1fr; }
    .zq-info-grid { grid-template-columns: repeat(2, 1fr); }
    .zq-filters { flex-direction: column; align-items: stretch; }
    .zq-comm-box { flex-direction: column; }
    .zq-admin-comm-grid { margin-left: 0; }
    .zq-vendor-meta { display: none; }
  }
  @media (max-width: 500px) {
    .zq-info-grid { grid-template-columns: 1fr; }
    .zq-stats-grid { grid-template-columns: 1fr 1fr; }
  }

  /* ── Portal Nav ─────────────────────────────────── */
  .zp-portal-nav { display:flex;align-items:center;gap:4px;padding:10px 0 14px;margin-bottom:12px;border-bottom:1px solid var(--rule, #e0e0e0); }
  .zp-portal-nav a { font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;color:var(--ink-3, #6b6b6b);padding:5px 14px;border-radius:4px;transition:all 0.18s ease; }
  .zp-portal-nav a:hover { color:var(--ink, #0e0e0e);background:var(--surface-2, #f7f7f7); }
  .zp-portal-nav a.zp-nav-active { color:#fff;background:var(--ink, #0e0e0e); }
  @media (max-width: 500px) {
    .zp-portal-nav { gap:2px; }
    .zp-portal-nav a { font-size:11px;padding:4px 10px; }
  }
{% endstyle %}
<div id="nuvio-qp-cfg" data-api-base="{{ section.settings.api_base | default: 'https://nuvio-quoting-portal-production.up.railway.app' }}" style="display:none;"></div>
<div class="zq">
  {% comment %} LOGIN {% endcomment %}
  <div id="zq-login-screen">
    <div class="zq-login-wrap">
      <div class="zq-login-box zq-fade-up">
        <div class="zq-login-header">
          <img class="zq-wordmark-img" src="https://nuvio.com.au/cdn/shop/files/Nuvio-BLACK_b23ebc01-28ae-47fa-ae5d-76f186047f60.svg?v=1706175394&width=240" alt="Nuvio" width="140" height="48" />
          <p>Trade quote portal</p>
        </div>
        <div class="zq-card">
          <div class="zq-field">
            <label class="zq-label">Email</label>
            <input class="zq-input" type="email" id="zq-email" placeholder="you@nuvio.com.au" />
          </div>
          <div class="zq-field" style="margin-bottom:20px;">
            <label class="zq-label">Password</label>
            <input class="zq-input" type="password" id="zq-pass" placeholder="••••••••" />
          </div>
          <button class="zq-btn zq-btn-primary zq-btn-full" id="zq-login-btn">Sign in</button>
          <p class="zq-err" id="zq-err" style="display:none;text-align:center;margin-top:12px;">Incorrect email or password</p>
        </div>
      </div>
    </div>
  </div>
  {% comment %} OTP SCREEN {% endcomment %}
  <div id="zq-otp-screen" style="display:none;">
    <div class="zq-login-wrap">
      <div class="zq-login-box zq-fade-up">
        <div class="zq-login-header">
          <img class="zq-wordmark-img" src="https://nuvio.com.au/cdn/shop/files/Nuvio-BLACK_b23ebc01-28ae-47fa-ae5d-76f186047f60.svg?v=1706175394&width=240" alt="Nuvio" width="140" height="48" />
          <p>Check your email</p>
        </div>
        <div class="zq-card">
          <p style="font-size:13px;color:var(--ink-3);margin-bottom:20px;text-align:center;">We sent a 6-digit code to <strong id="zq-otp-email-label"></strong></p>
          <div class="zq-field" style="margin-bottom:20px;">
            <label class="zq-label">Verification code</label>
            <input class="zq-input" type="text" id="zq-otp-code" placeholder="000000" maxlength="6" style="font-size:24px;letter-spacing:0.2em;text-align:center;" autocomplete="one-time-code" />
          </div>
          <button class="zq-btn zq-btn-primary zq-btn-full" id="zq-otp-verify-btn">Verify</button>
          <p class="zq-err" id="zq-otp-err" style="display:none;text-align:center;margin-top:12px;"></p>
          <button class="zq-btn zq-btn-ghost zq-btn-full" id="zq-otp-back-btn" style="margin-top:8px;color:var(--ink-4);font-size:12px;">← Back to login</button>
        </div>
      </div>
    </div>
  </div>
  {% comment %} DASHBOARD {% endcomment %}
  <div id="zq-dashboard" style="display:none;">
    <div class="zp-portal-nav">
      {%- if section.settings.admin_url != blank -%}<a href="{{ section.settings.admin_url }}">Admin Portal</a>{%- endif -%}
      <a href="#" class="zp-nav-active">Quote Portal</a>
      {%- if section.settings.bundles_url != blank -%}<a href="{{ section.settings.bundles_url }}">Bundles</a>{%- endif -%}
      {%- if section.settings.stock_url != blank -%}<a href="{{ section.settings.stock_url }}">Stock</a>{%- endif -%}
      {%- if section.settings.pricelist_url != blank -%}<a href="{{ section.settings.pricelist_url }}">Price Lists</a>{%- endif -%}
    </div>
    <div class="zq-topbar">
      <div class="zq-topbar-left">
        <p class="zq-page-title">Nuvio Quoting Portal</p>
        <span class="zq-syncing" id="zq-sync-status"></span>
      </div>
      <div class="zq-topbar-right">
        <span id="zq-user-label" style="font-size:12px;color:var(--ink-4);margin-right:4px;"></span>
        <button class="zq-btn zq-btn-sm" id="zq-forecast-btn" style="display:none;">Forecasting</button>
        <button class="zq-btn zq-btn-sm" id="zq-orders-btn" style="display:none;">Orders</button>
        <button class="zq-btn zq-btn-primary zq-btn-sm" id="zq-new-quote-btn">+ New quote</button>
        <button class="zq-btn zq-btn-ghost zq-btn-sm" id="zq-logout-btn">Sign out</button>
      </div>
    </div>
    <div class="zq-comm-box">
      <div class="zq-comm-primary">
        <div class="zq-comm-label" id="zq-comm-title">Monthly commission</div>
        <div class="zq-comm-value" id="zq-comm-value">$0.00</div>
        <div class="zq-comm-sub" id="zq-comm-sub"></div>
        <div class="zq-comm-breakdown" id="zq-comm-breakdown"></div>
      </div>
      <div id="zq-admin-comm-wrap" style="display:none;flex:1;margin-left:16px;">
        <div class="zq-admin-comm-grid" id="zq-admin-comm-grid"></div>
      </div>
      <div class="zq-comm-month" style="flex-shrink:0;">
        <select id="zq-comm-month-sel"></select>
      </div>
    </div>
    <div class="zq-stats-grid">
      <div class="zq-stat"><div class="zq-stat-label">Pending</div><div class="zq-stat-value" id="zq-s-pending">—</div></div>
      <div class="zq-stat"><div class="zq-stat-label">Sent this week</div><div class="zq-stat-value" id="zq-s-sent">—</div></div>
      <div class="zq-stat"><div class="zq-stat-label">Converted</div><div class="zq-stat-value" id="zq-s-conv">—</div></div>
      <div class="zq-stat"><div class="zq-stat-label">Conversion rate</div><div class="zq-stat-value" id="zq-s-rate">—</div></div>
    </div>
    <div class="zq-tabs">
      <button class="zq-tab active" data-filter="all">All</button>
      <button class="zq-tab" data-filter="pending">Pending</button>
      <button class="zq-tab" data-filter="sent">Sent</button>
      <button class="zq-tab" data-filter="converted">Converted</button>
    </div>
    <div class="zq-filters">
      <input class="zq-search-bar" id="zq-quote-search" placeholder="Search by customer, company or quote ID…" />
      <button class="zq-btn zq-btn-sm zq-btn-primary" id="zq-search-btn">Search</button>
      <select class="zq-filter-select" id="zq-sp-filter"><option value="all">All salespeople</option></select>
    </div>
    <div id="zq-list"></div>
  </div>
  {% comment %} FORECAST {% endcomment %}
  <div id="zq-forecast-screen" style="display:none;">
    <div class="zq-screen-header">
      <button class="zq-btn zq-btn-sm" id="zq-forecast-back-btn">← Back</button>
      <p class="zq-page-title">Forecasting</p>
      <div class="zq-screen-header-actions">
        <div id="zq-fc-stock-controls" style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
          <select class="zq-filter-select" id="zq-fc-vendor-filter"><option value="all">All suppliers</option></select>
          <input class="zq-search-bar" id="zq-fc-search" placeholder="Search SKU or product…" style="min-width:180px;flex:unset;" />
          <button class="zq-btn zq-btn-sm" id="zq-fc-needs-order-btn">Order needed only</button>
          <button class="zq-btn zq-btn-sm" id="zq-fc-refresh-btn">↻ Refresh</button>
          <button class="zq-btn zq-btn-sm" id="zq-fc-send-alert-btn">✉ Send alert now</button>
        </div>
        <div id="zq-fc-po-controls" style="display:none;">
          <button class="zq-btn zq-btn-primary zq-btn-sm" id="zq-new-po-btn">+ New purchase order</button>
        </div>
        <div id="zq-fc-costs-controls" style="display:none;align-items:center;gap:8px;flex-wrap:wrap;">
          <input class="zq-search-bar" id="cost-search" placeholder="Search products…" style="min-width:200px;flex:unset;" autocomplete="off" />
          <button class="zq-btn zq-btn-primary zq-btn-sm" id="zq-save-costs-btn">Save all costs</button>
        </div>
        <div id="zq-fc-calc-controls" style="display:none;align-items:center;gap:8px;flex-wrap:wrap;">
          <input class="zq-search-bar" id="calc-search" placeholder="Search products…" style="min-width:200px;flex:unset;" autocomplete="off" />
          <button class="zq-btn zq-btn-primary zq-btn-sm" id="zq-save-calc-btn">Save calculations</button>
        </div>
      </div>
    </div>
    <div class="zq-fc-tabs">
      <button class="zq-fc-tab active" data-fc-tab="stock">Stock levels</button>
      <button class="zq-fc-tab" data-fc-tab="pos">Purchase orders</button>
      <button class="zq-fc-tab" data-fc-tab="costs">Cost prices</button>
      <button class="zq-fc-tab" data-fc-tab="calc">Cost calculations</button>
    </div>
    <div id="zq-fc-stock-panel">
      <div id="zq-fc-loading" class="zq-loading" style="display:none;">Loading inventory…</div>
      <div id="zq-fc-body"></div>
    </div>
    <div id="zq-fc-po-panel" style="display:none;">
      <div id="zq-po-list"></div>
    </div>
    <div id="zq-fc-costs-panel" style="display:none;">
      <div id="zq-cost-list"></div>
    </div>
    <div id="zq-fc-calc-panel" style="display:none;">
      <div class="zq-card zq-card-sm" style="margin-bottom:16px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
        <label class="zq-label" style="margin:0;white-space:nowrap;">AUD/USD rate</label>
        <div style="display:flex;align-items:center;gap:6px;">
          <input type="number" min="0.01" max="2" step="0.001" id="calc-audusd" placeholder="e.g. 0.63" style="width:100px;padding:7px 10px;border:1px solid var(--rule);border-radius:var(--radius);font-size:14px;font-family:'Barlow',sans-serif;background:var(--surface);color:var(--ink);" />
          <span style="font-size:13px;color:var(--ink-4);">1 AUD = <span id="calc-audusd-display">—</span> USD</span>
        </div>
        <span style="font-size:12px;color:var(--ink-4);margin-left:4px;">Used to convert USD costs to AUD</span>
      </div>
      <div id="zq-calc-list"></div>
    </div>
  </div>
  {% comment %} NEW PO {% endcomment %}
  <div id="zq-new-po-screen" style="display:none;">
    <div class="zq-screen-header">
      <button class="zq-btn zq-btn-sm" id="zq-new-po-back-btn">← Back</button>
      <p class="zq-page-title" id="zq-new-po-title">New purchase order</p>
    </div>
    <div class="zq-two-col">
      <div class="zq-card">
        <p class="zq-section-title">Order details</p>
        <div class="zq-field"><label class="zq-label">Supplier *</label><input class="zq-input" id="po-supplier" placeholder="e.g. Watersino" /></div>
        <div class="zq-field"><label class="zq-label">Reference number</label><input class="zq-input" id="po-ref" placeholder="e.g. JD04202602" /></div>
        <div class="zq-field"><label class="zq-label">Expected arrival</label><input class="zq-input" type="date" id="po-arrival" /></div>
        <div class="zq-field"><label class="zq-label">Notes</label><textarea class="zq-input" id="po-notes" placeholder="Any notes…"></textarea></div>
      </div>
      <div class="zq-stack">
        <div class="zq-card">
          <p class="zq-section-title">Products</p>
          <div id="po-products-loading" class="zq-loading" style="display:none;">Loading products…</div>
          <div class="zq-field zq-search-wrap">
            <label class="zq-label">Search & add products</label>
            <input class="zq-input" id="po-search" placeholder="Type product name or SKU…" autocomplete="off" />
            <div id="po-search-results" class="zq-search-results" style="display:none;"></div>
          </div>
          <div id="po-items"></div>
          <div id="po-empty" class="zq-empty">No products added yet.</div>
