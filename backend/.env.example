# ----- Server -----
PORT=3000
NODE_ENV=production

# Railway injects DATABASE_URL automatically when you add a Postgres plugin.
DATABASE_URL=postgres://user:pass@host:5432/nuvio_quoting

# Comma-separated list of origins allowed to call the API (the Shopify storefront domain)
ALLOWED_ORIGIN=https://nuvio.com,https://nuvio.myshopify.com

# Simple shared-secret auth header required on every /api/* request.
# The Liquid section sends this as `x-portal-token`.
# Generate with: openssl rand -hex 32
PORTAL_TOKEN=replace-me-with-a-long-random-hex-string

# ----- Shopify Admin API -----
SHOPIFY_STORE_DOMAIN=nuvio.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-10

# ----- Company details for PDF quote headers -----
COMPANY_NAME=Nuvio
COMPANY_ADDRESS=Nuvio HQ, Australia
COMPANY_EMAIL=sales@nuvio.com.au
